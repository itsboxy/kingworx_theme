[
  {
    "name": "theme_info",
    "theme_name": "KingWorX",
    "theme_version": "1.0.0",
    "theme_author": "KingWorX Pty Ltd",
    "theme_documentation_url": "https://kingworx.com.au",
    "theme_support_url": "https://kingworx.com.au/pages/contact"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "barlow_n4",
        "label": "Body font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "barlow_condensed_n7",
        "label": "Heading font"
      },
      {
        "type": "range",
        "id": "font_body_size",
        "min": 14,
        "max": 18,
        "step": 1,
        "unit": "px",
        "label": "Body font size",
        "default": 16
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "header",
        "content": "Brand Colors"
      },
      {
        "type": "color",
        "id": "color_brand",
        "default": "#c60000",
        "label": "Brand Red"
      },
      {
        "type": "color",
        "id": "color_brand_hover",
        "default": "#a50000",
        "label": "Brand Red (Hover)"
      },
      {
        "type": "header",
        "content": "Background"
      },
      {
        "type": "color",
        "id": "background_color",
        "default": "#0a0a0a",
        "label": "Page Background"
      },
      {
        "type": "color",
        "id": "color_surface",
        "default": "#111111",
        "label": "Card / Surface"
      },
      {
        "type": "color",
        "id": "color_surface_2",
        "default": "#1c1c1c",
        "label": "Surface Elevated"
      },
      {
        "type": "header",
        "content": "Text"
      },
      {
        "type": "color",
        "id": "foreground_color",
        "default": "#ffffff",
        "label": "Primary Text"
      },
      {
        "type": "color",
        "id": "color_muted",
        "default": "#888888",
        "label": "Muted Text"
      },
      {
        "type": "header",
        "content": "Borders"
      },
      {
        "type": "color",
        "id": "color_border",
        "default": "#2a2a2a",
        "label": "Border Color"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "Page width",
        "options": [
          {
            "value": "90rem",
            "label": "Narrow (1440px)"
          },
          {
            "value": "110rem",
            "label": "Wide (1760px)"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 60,
        "step": 5,
        "unit": "px",
        "label": "Page margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 8,
        "step": 1,
        "unit": "px",
        "label": "Input corner radius",
        "default": 2
      },
      {
        "type": "range",
        "id": "card_corner_radius",
        "min": 0,
        "max": 12,
        "step": 1,
        "unit": "px",
        "label": "Card corner radius",
        "default": 4
      }
    ]
  },
  {
    "name": "Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 300,
        "step": 10,
        "unit": "px",
        "label": "Logo width",
        "default": 160
      },
      {
        "type": "checkbox",
        "id": "header_sticky",
        "label": "Sticky header",
        "default": true
      }
    ]
  },
  {
    "name": "Announcement Bar",
    "settings": [
      {
        "type": "checkbox",
        "id": "announcement_bar_enabled",
        "label": "Show announcement bar",
        "default": true
      },
      {
        "type": "text",
        "id": "announcement_text",
        "label": "Announcement text",
        "default": "FREE SHIPPING ON ORDERS OVER $150 | ENGINEERED IN AUSTRALIA, BUILT FOR PERFORMANCE"
      },
      {
        "type": "url",
        "id": "announcement_url",
        "label": "Announcement link"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          {
            "value": "page",
            "label": "Cart page"
          },
          {
            "value": "drawer",
            "label": "Drawer"
          }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_note",
        "label": "Enable cart note",
        "default": true
      }
    ]
  },
  {
    "name": "Social Media",
    "settings": [
      {
        "type": "header",
        "content": "Social Links"
      },
      {
        "type": "url",
        "id": "social_instagram",
        "label": "Instagram URL"
      },
      {
        "type": "url",
        "id": "social_facebook",
        "label": "Facebook URL"
      },
      {
        "type": "url",
        "id": "social_youtube",
        "label": "YouTube URL"
      },
      {
        "type": "url",
        "id": "social_tiktok",
        "label": "TikTok URL"
      }
    ]
  },
  {
    "name": "Footer",
    "settings": [
      {
        "type": "text",
        "id": "footer_tagline",
        "label": "Footer tagline",
        "default": "Engineering-driven performance parts for the serious driver."
      },
      {
        "type": "checkbox",
        "id": "show_payment_icons",
        "label": "Show payment icons",
        "default": true
      }
    ]
  }
]
