<section class="cart-page section-padding">
  <h1 class="cart-page__title">Your Cart</h1>

  {% if cart.item_count > 0 %}
    <div class="cart-page__layout">

      <!-- Cart Items -->
      <div class="cart-page__items">
        <form action="/cart" method="post" id="cart-form">
          <div class="cart-items-header">
            <span>Product</span>
            <span>Price</span>
            <span>Qty</span>
            <span>Total</span>
          </div>

          {% for item in cart.items %}
            <div class="cart-page__item">
              <div class="cart-page__item-product">
                <a href="{{ item.url }}" class="cart-page__item-image">
                  {% if item.image %}
                    <img
                      src="{{ item.image | image_url: width: 160 }}"
                      alt="{{ item.image.alt | default: item.title | escape }}"
                      loading="lazy"
                      width="80"
                      height="80"
                    >
                  {% endif %}
                </a>
                <div class="cart-page__item-details">
                  <a href="{{ item.url }}" class="cart-page__item-title">{{ item.product.title }}</a>
                  {% unless item.product.has_only_default_variant %}
                    <p class="cart-page__item-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  {% if item.selling_plan_allocation %}
                    <p class="cart-page__item-variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                  {% endif %}
                  <button
                    type="button"
                    class="cart-page__item-remove"
                    onclick="removeCartItem('{{ item.key }}')"
                  >
                    Remove
                  </button>
                </div>
              </div>

              <div class="cart-page__item-price">
                {{ item.original_price | money }}
              </div>

              <div class="cart-page__item-qty">
                <div class="quantity-selector">
                  <button
                    type="button"
                    class="quantity-selector__btn"
                    onclick="updateCartQty('{{ item.key }}', {{ item.quantity | minus: 1 }})"
                  >−</button>
                  <input
                    type="number"
                    class="quantity-selector__input"
                    value="{{ item.quantity }}"
                    min="0"
                    onchange="updateCartQty('{{ item.key }}', this.value)"
                    aria-label="Quantity for {{ item.title }}"
                  >
                  <button
                    type="button"
                    class="quantity-selector__btn"
                    onclick="updateCartQty('{{ item.key }}', {{ item.quantity | plus: 1 }})"
                  >+</button>
                </div>
              </div>

              <div class="cart-page__item-total">
                {{ item.final_line_price | money }}
              </div>
            </div>
          {% endfor %}
        </form>

        {% if settings.cart_show_note %}
          <div class="cart-note">
            <label for="cart-note" class="form-label">Order Note (optional)</label>
            <textarea
              id="cart-note"
              name="note"
              class="cart-note__input"
              placeholder="Special instructions, delivery notes..."
              rows="3"
            >{{ cart.note }}</textarea>
          </div>
        {% endif %}
      </div>

      <!-- Cart Summary -->
      <div class="cart-page__summary">
        <div class="cart-summary">
          <h3 class="cart-summary__title">Order Summary</h3>

          <div class="cart-summary__row">
            <span>Subtotal ({{ cart.item_count }} items)</span>
            <span>{{ cart.original_total_price | money }}</span>
          </div>

          {% if cart.total_discount > 0 %}
            <div class="cart-summary__row cart-summary__row--discount">
              <span>Savings</span>
              <span>–{{ cart.total_discount | money }}</span>
            </div>
          {% endif %}

          <div class="cart-summary__row">
            <span>Shipping</span>
            <span class="cart-summary__shipping">Calculated at checkout</span>
          </div>

          <div class="cart-summary__divider"></div>

          <div class="cart-summary__row cart-summary__row--total">
            <span>Total</span>
            <span>{{ cart.total_price | money }} <small>AUD</small></span>
          </div>

          <a href="/checkout" class="btn btn--primary btn--full btn--large cart-summary__checkout">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Proceed to Checkout
          </a>

          <a href="{{ routes.all_products_collection_url }}" class="btn btn--secondary btn--full cart-summary__continue">
            Continue Shopping
          </a>

          <div class="cart-summary__trust">
            <span>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              Secure, encrypted checkout
            </span>
          </div>

          {% if settings.show_payment_icons %}
            <div class="cart-summary__payment-icons">
              {% for type in shop.enabled_payment_types %}
                {{ type | payment_type_svg_tag: class: 'payment-icon' }}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

    </div>

  {% else %}
    <div class="cart-empty">
      <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <h2>Your cart is empty</h2>
      <p>Looks like you haven't added any parts yet.</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary btn--large">Start Shopping</a>
    </div>
  {% endif %}
</section>

<script>
  function updateCartQty(key, qty) {
    qty = parseInt(qty);
    if (qty < 0) qty = 0;
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    }).then(function() { window.location.reload(); });
  }

  function removeCartItem(key) {
    updateCartQty(key, 0);
  }

  function addToCart(variantId, qty) {
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: qty || 1 })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      // Open cart drawer if enabled
      var drawer = document.getElementById('cart-drawer');
      if (drawer) {
        refreshCartDrawer();
        drawer.classList.add('is-open');
        document.getElementById('cart-overlay').classList.add('is-open');
      } else {
        window.location.href = '/cart';
      }
    });
  }
</script>

{% stylesheet %}
  .cart-page {
    padding: var(--spacing-lg) var(--page-margin) var(--spacing-2xl);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .cart-page__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin-bottom: var(--spacing-lg);
  }

  .cart-page__layout {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: var(--spacing-xl);
    align-items: start;
  }

  @media (max-width: 900px) {
    .cart-page__layout { grid-template-columns: 1fr; }
  }

  /* Items header */
  .cart-items-header {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 1.5rem;
    padding: 0.5rem 0 0.75rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0;
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .cart-items-header > :not(:first-child) { text-align: right; }

  /* Cart item */
  .cart-page__item {
    display: grid;
    grid-template-columns: 1fr auto auto auto;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
    align-items: center;
  }

  .cart-page__item-product {
    display: flex;
    gap: 1rem;
  }

  .cart-page__item-image {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    background: var(--color-surface-2);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .cart-page__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cart-page__item-title {
    font-family: var(--font-heading--family);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
    display: block;
    margin-bottom: 0.25rem;
  }

  .cart-page__item-title:hover { color: var(--color-brand); }

  .cart-page__item-variant {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin: 0;
  }

  .cart-page__item-remove {
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 0.72rem;
    cursor: pointer;
    padding: 0;
    margin-top: 0.4rem;
    text-decoration: underline;
    display: inline-block;
    transition: color var(--transition-fast);
  }

  .cart-page__item-remove:hover { color: var(--color-brand); }

  .cart-page__item-price,
  .cart-page__item-total {
    font-family: var(--font-heading--family);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-foreground);
    text-align: right;
    white-space: nowrap;
  }

  @media (max-width: 640px) {
    .cart-items-header { display: none; }
    .cart-page__item { grid-template-columns: 1fr auto; gap: 0.75rem; }
    .cart-page__item-price { display: none; }
  }

  /* Cart note */
  .cart-note {
    margin-top: 1.5rem;
  }

  .cart-note__input {
    resize: vertical;
    min-height: 80px;
  }

  /* Summary */
  .cart-summary {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-cards);
    padding: 1.5rem;
    position: sticky;
    top: calc(var(--header-height) + 1rem);
  }

  .cart-summary__title {
    font-size: 1rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .cart-summary__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .cart-summary__row--discount { color: #4caf50; }

  .cart-summary__shipping { font-size: 0.78rem; }

  .cart-summary__divider {
    height: 1px;
    background: var(--color-border);
    margin: 0.75rem 0;
  }

  .cart-summary__row--total {
    font-family: var(--font-heading--family);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-foreground);
    padding: 0.5rem 0 1.25rem;
  }

  .cart-summary__row--total small {
    font-size: 0.7rem;
    color: var(--color-muted);
    font-weight: 400;
    margin-left: 0.25rem;
  }

  .cart-summary__checkout {
    margin-bottom: 0.6rem;
  }

  .cart-summary__continue {
    margin-bottom: 1.25rem;
  }

  .cart-summary__trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.72rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .cart-summary__trust svg { color: var(--color-brand); }

  .cart-summary__payment-icons {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  /* Empty state */
  .cart-empty {
    text-align: center;
    padding: var(--spacing-2xl) var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .cart-empty svg { color: var(--color-border); }
  .cart-empty h2 { margin: 0; }
  .cart-empty p { color: var(--color-muted); margin: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart"
}
{% endschema %}
