<div class="generic-page-hero full-width">
  <div class="generic-page-hero__inner">
    <h1 class="generic-page-hero__title">{{ page.title }}</h1>
  </div>
</div>

{% if page.content != blank %}
  <div class="generic-page-body">
    <div class="rte">{{ page.content }}</div>
  </div>
{% endif %}

{% stylesheet %}
  .generic-page-hero {
    background: #111111;
    border-bottom: 3px solid var(--color-brand);
    padding: 3rem var(--page-margin);
  }
  .generic-page-hero__inner {
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .generic-page-hero__title {
    font-size: clamp(1.8rem, 4vw, 3rem);
    color: #ffffff;
    margin: 0;
  }

  .generic-page-body {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem var(--page-margin) 5rem;
  }
  .generic-page-body .rte {
    font-size: 1rem;
    line-height: 1.8;
    color: #444444;
  }
  .generic-page-body .rte h2,
  .generic-page-body .rte h3 {
    color: #111111;
    margin-top: 2rem;
    font-size: 1.3rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}
