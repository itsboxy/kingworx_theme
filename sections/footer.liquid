<footer class="site-footer full-width" role="contentinfo">
  <div class="site-footer__inner">

    <!-- Footer Top -->
    <div class="site-footer__top">

      <!-- Brand Column -->
      <div class="site-footer__brand">
        <a href="{{ routes.root_url }}" class="site-footer__logo" aria-label="{{ shop.name }} - Home">
          {% if settings.logo %}
            <img src="{{ settings.logo | image_url: width: 280 }}" alt="{{ shop.name }}" width="140" loading="lazy" style="max-height:3rem;width:auto;object-fit:contain;">
          {% else %}
            <img
              src="{{ 'kingworxlogo.png' | asset_url }}"
              alt="{{ shop.name }}"
              width="140"
              loading="lazy"
              style="max-height:3rem;width:auto;object-fit:contain;"
            >
          {% endif %}
        </a>
        <p class="site-footer__tagline">{{ settings.footer_tagline }}</p>
        <div class="site-footer__social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" class="social-icon" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {% endif %}
          {% if settings.social_facebook != blank %}
            <a href="{{ settings.social_facebook }}" class="social-icon" target="_blank" rel="noopener" aria-label="Facebook">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_youtube != blank %}
            <a href="{{ settings.social_youtube }}" class="social-icon" target="_blank" rel="noopener" aria-label="YouTube">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" class="social-icon" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.2 8.2 0 004.79 1.54V6.78a4.85 4.85 0 01-1.02-.09z"/></svg>
            </a>
          {% endif %}
        </div>
      </div>

      <!-- Link Columns -->
      {% if section.settings.menu_1 != blank %}
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">{{ section.settings.menu_1_title | default: 'Shop' }}</h4>
          <ul class="site-footer__links">
            {% for link in section.settings.menu_1.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      {% if section.settings.menu_2 != blank %}
        <div class="site-footer__col">
          <h4 class="site-footer__col-title">{{ section.settings.menu_2_title | default: 'Info' }}</h4>
          <ul class="site-footer__links">
            {% for link in section.settings.menu_2.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}

      <!-- Newsletter Column -->
      <div class="site-footer__col site-footer__col--newsletter">
        <h4 class="site-footer__col-title">Stay in the Loop</h4>
        <p class="site-footer__newsletter-desc">New parts, builds, and deals. No spam.</p>
        <form method="post" action="/contact#newsletter" class="site-footer__newsletter">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="✓">
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            placeholder="your@email.com"
            class="site-footer__newsletter-input"
            aria-label="Email address"
            required
          >
          <button type="submit" class="btn btn--primary">Subscribe</button>
        </form>
      </div>

    </div>

    <!-- Footer Bottom -->
    <div class="site-footer__bottom">
      <p class="site-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved. Built in Australia.
      </p>
      <div class="site-footer__legal">
        <a href="/pages/privacy">Privacy</a>
        <a href="/pages/terms">Terms</a>
        <a href="/pages/returns">Returns</a>
        <a href="/pages/shipping">Shipping</a>
        <a href="/pages/about">Our Story</a>
      </div>
      {% if settings.show_payment_icons %}
        <div class="site-footer__payment">
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag: class: 'payment-icon' }}
          {% endfor %}
        </div>
      {% endif %}
    </div>

  </div>
</footer>

{% stylesheet %}
  .site-footer {
    background: linear-gradient(180deg, #0a0a0a 0%, #050505 100%);
    border-top: 1px solid var(--color-border);
    margin-top: var(--spacing-2xl);
    position: relative;
    overflow: hidden;
  }
  .site-footer::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand) 30%, var(--color-brand) 70%, transparent);
  }

  .site-footer__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--page-margin);
  }

  /* Footer Top */
  .site-footer__top {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.8fr;
    gap: var(--spacing-xl);
    padding: var(--spacing-2xl) 0 var(--spacing-xl);
    border-bottom: 1px solid var(--color-border);
  }

  @media (max-width: 1024px) {
    .site-footer__top {
      grid-template-columns: 1fr 1fr;
    }
    .site-footer__brand { grid-column: 1 / -1; }
  }

  @media (max-width: 600px) {
    .site-footer__top { grid-template-columns: 1fr; }
  }

  /* Brand column */
  .site-footer__logo {
    display: inline-block;
    margin-bottom: 1rem;
  }

  .site-footer__logo-text {
    font-family: var(--font-heading--family);
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--color-foreground);
  }

  .site-footer__tagline {
    font-size: 0.875rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 28ch;
    margin-bottom: 1.5rem;
  }

  .site-footer__social {
    display: flex;
    gap: 0.5rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    color: var(--color-muted);
    transition: all var(--transition-fast);
  }

  .social-icon:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
  }

  /* Link columns */
  .site-footer__col-title {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .site-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .site-footer__links a {
    font-size: 0.875rem;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .site-footer__links a:hover {
    color: var(--color-brand);
  }

  /* Newsletter */
  .site-footer__newsletter-desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-bottom: 1rem;
  }

  .site-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .site-footer__newsletter-input {
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-foreground);
    font-size: 0.875rem;
    padding: 0.75rem 1rem;
    outline: none;
    transition: border-color var(--transition-fast);
    width: 100%;
  }

  .site-footer__newsletter-input:focus {
    border-color: var(--color-brand);
  }

  .site-footer__newsletter .btn {
    align-self: flex-start;
  }

  /* Footer Bottom */
  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1.5rem 0;
  }

  .site-footer__copyright {
    font-size: 0.78rem;
    color: var(--color-muted);
    margin: 0;
  }

  .site-footer__legal {
    display: flex;
    gap: 1.25rem;
  }

  .site-footer__legal a {
    font-size: 0.78rem;
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .site-footer__legal a:hover {
    color: var(--color-brand);
  }

  .site-footer__payment {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .payment-icon {
    height: 1.5rem;
    width: auto;
    opacity: 0.6;
    filter: invert(1) brightness(0.7);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "Column 1 heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "Column 1 menu"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "Column 2 heading",
      "default": "Support"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "Column 2 menu"
    }
  ]
}
{% endschema %}
