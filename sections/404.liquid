<section class="not-found full-width">
  <div class="not-found__slash" aria-hidden="true"></div>
  <div class="not-found__inner">
    <div class="not-found__code" aria-hidden="true">404</div>
    <div class="not-found__content">
      <p class="not-found__eyebrow">Page Not Found</p>
      <h1 class="not-found__heading">Wrong Turn.<br><span class="not-found__accent">Let's Get You Back.</span></h1>
      <p class="not-found__sub">The page you're looking for doesn't exist or has been moved. Head back to the shop and find your next build part.</p>
      <div class="not-found__actions">
        <a href="{{ routes.root_url }}" class="btn btn--primary btn--large">Back to Home</a>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--ghost btn--large">Shop All Parts</a>
      </div>
      <div class="not-found__links">
        <span>Quick links:</span>
        <a href="/collections/aero-kits">Aero Kits</a>
        <a href="/collections/performance">Performance</a>
        <a href="/collections/suspension">Suspension</a>
        <a href="/pages/contact">Contact Us</a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .not-found {
    background: #111111;
    min-height: 80vh;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
  }

  .not-found__slash {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -65deg,
      transparent 0, transparent 60px,
      rgba(198,0,0,0.04) 60px, rgba(198,0,0,0.04) 61px
    );
    pointer-events: none;
  }

  .not-found__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 6rem var(--page-margin);
    display: flex;
    align-items: center;
    gap: 4rem;
    width: 100%;
  }

  .not-found__code {
    font-family: var(--font-heading--family);
    font-size: clamp(8rem, 20vw, 16rem);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 2px rgba(198,0,0,0.25);
    flex-shrink: 0;
    user-select: none;
    position: relative;
  }
  .not-found__code::after {
    content: '404';
    position: absolute;
    inset: 0;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.04);
    transform: translate(4px, 4px);
  }

  .not-found__content { flex: 1; min-width: 0; }

  .not-found__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .not-found__eyebrow::before {
    content: '';
    display: inline-block;
    width: 2rem; height: 2px;
    background: var(--color-brand);
  }

  .not-found__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
  }
  .not-found__accent { color: var(--color-brand); }

  .not-found__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.7;
    max-width: 50ch;
    margin-bottom: 2.5rem;
  }

  .not-found__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .not-found__links {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.78rem;
  }
  .not-found__links span {
    font-family: var(--font-heading--family);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.3);
  }
  .not-found__links a {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    transition: color var(--transition-fast);
    border-bottom: 1px solid rgba(255,255,255,0.15);
    padding-bottom: 1px;
  }
  .not-found__links a:hover { color: var(--color-brand); border-color: var(--color-brand); }

  @media (max-width: 768px) {
    .not-found__inner { flex-direction: column; gap: 1rem; padding: 4rem var(--page-margin); }
    .not-found__code { font-size: clamp(5rem, 25vw, 8rem); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "404",
  "settings": []
}
{% endschema %}
