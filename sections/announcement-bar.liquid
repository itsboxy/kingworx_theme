{% if settings.announcement_bar_enabled %}
<div class="announcement-bar full-width" role="region" aria-label="Announcement">
  <div class="announcement-bar__inner">
    {% if settings.announcement_url != blank %}
      <a href="{{ settings.announcement_url }}" class="announcement-bar__text">
        {{ settings.announcement_text }}
      </a>
    {% else %}
      <span class="announcement-bar__text">{{ settings.announcement_text }}</span>
    {% endif %}
  </div>
</div>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    background: var(--color-brand);
    min-height: var(--announcement-height);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .announcement-bar__inner {
    text-align: center;
    padding: 0.5rem var(--page-margin);
  }

  .announcement-bar__text {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #ffffff;
    text-decoration: none;
  }

  a.announcement-bar__text:hover {
    opacity: 0.85;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
