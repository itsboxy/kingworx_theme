<!-- OUR STORY — KingWorX About Page -->

<!-- Hero Banner -->
<div class="about-hero full-width">
  <div class="about-hero__slash"></div>
  <div class="about-hero__inner">
    <p class="about-hero__eyebrow">Est. 2024 · Engineered in Australia</p>
    <h1 class="about-hero__heading">
      Built Different.<br>
      <span class="about-hero__heading-accent">Made to Last.</span>
    </h1>
    <p class="about-hero__sub">
      We started with one question: why do quality aero and performance parts cost a fortune
      in Australia? The answer changed everything — and gave rise to KingWorX.
    </p>
  </div>
  <div class="about-hero__ambient"></div>
</div>

<!-- Origin Story -->
<div class="about-section about-origin full-width">
  <div class="about-slash-line"></div>
  <div class="about-origin__grid">
    <div class="about-origin__text">
      <p class="section-eyebrow">The Beginning</p>
      <h2 class="about-origin__heading">A Garage, a CAD Seat, and a Problem to Solve</h2>
      <p>
        KingWorX was born out of frustration. Our founder — a passionate car enthusiast and mechanical
        engineer — spent years watching Australian car builders pay premium prices for parts that were
        just mediocre in fitment, finish, and function. The industry gap was obvious: no one was
        designing parts <em>specifically</em> for the cars Australians actually drive.
      </p>
      <p>
        So we sat down at a CAD workstation, modelled our first underbody component from scratch,
        and had it manufactured to tight tolerances. The result? Parts that actually fit. Every time.
      </p>
    </div>
    <div class="about-origin__stat-stack">
      <div class="about-stat">
        <span class="about-stat__num">100<span class="about-stat__unit">%</span></span>
        <span class="about-stat__label">CAD Designed in Australia</span>
      </div>
      <div class="about-stat">
        <span class="about-stat__num">0<span class="about-stat__unit">mm</span></span>
        <span class="about-stat__label">Tolerance on Critical Fitment Dims</span>
      </div>
      <div class="about-stat">
        <span class="about-stat__num">2024</span>
        <span class="about-stat__label">Year Founded</span>
      </div>
    </div>
  </div>
</div>

<!-- Diagonal Divider -->
<div class="about-diagonal full-width">
  <div class="about-diagonal__slash"></div>
  <div class="about-diagonal__content">
    <blockquote class="about-quote">
      <span class="about-quote__mark">"</span>
      We don't design parts for a catalogue. We design them for your specific car, your roads,
      your conditions — and we don't sign off until fitment is perfect.
      <span class="about-quote__mark">"</span>
    </blockquote>
    <p class="about-quote__attr">— KingWorX Founder</p>
  </div>
</div>

<!-- How We Build -->
<div class="about-section about-process full-width">
  <p class="section-eyebrow">How We Do It</p>
  <h2 class="about-process__heading">From Concept to Your Driveway</h2>
  <div class="about-process__steps">

    <div class="about-step">
      <div class="about-step__num">01</div>
      <div class="about-step__slash"></div>
      <div class="about-step__body">
        <h3>Research & Measurement</h3>
        <p>
          Every part begins with extensive research — OEM diagrams, physical measurements,
          and real-world fitment checks across target vehicles. No guessing, no spec sheets
          from suppliers.
        </p>
      </div>
    </div>

    <div class="about-step">
      <div class="about-step__num">02</div>
      <div class="about-step__slash"></div>
      <div class="about-step__body">
        <h3>CAD Engineering</h3>
        <p>
          Our engineers model every component in precision CAD. Mounting points, material
          thickness, structural ribs, aero profiles — all optimised digitally before a single
          piece of material is cut.
        </p>
      </div>
    </div>

    <div class="about-step">
      <div class="about-step__num">03</div>
      <div class="about-step__slash"></div>
      <div class="about-step__body">
        <h3>Precision Manufacturing</h3>
        <p>
          We work with hand-selected manufacturing partners in India — facilities with
          ISO-grade processes, CNC equipment, and a shared obsession with tolerances.
          Quality control happens at every stage, not just final inspection.
        </p>
      </div>
    </div>

    <div class="about-step">
      <div class="about-step__num">04</div>
      <div class="about-step__slash"></div>
      <div class="about-step__body">
        <h3>Test & Validate</h3>
        <p>
          Samples are shipped to Australia for physical fitment testing on real vehicles.
          If it doesn't pass our fitment standard, it goes back to engineering. No exceptions.
        </p>
      </div>
    </div>

    <div class="about-step">
      <div class="about-step__num">05</div>
      <div class="about-step__slash"></div>
      <div class="about-step__body">
        <h3>Ship Direct to You</h3>
        <p>
          Approved parts go into stock and ship directly to your door, Australia-wide.
          No middlemen. No retail markup. Factory-direct pricing with premium quality.
        </p>
      </div>
    </div>

  </div>
</div>

<!-- Values Grid -->
<div class="about-section about-values full-width">
  <div class="about-values__inner">
    <p class="section-eyebrow section-eyebrow--light">What Drives Us</p>
    <h2 class="about-values__heading">Our Values</h2>
    <div class="about-values__grid">

      <div class="about-value-card">
        <div class="about-value-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <h3>Integrity</h3>
        <p>We don't oversell specs or airbrush problems. If a part fits 95% of applications we say so — and tell you why.</p>
        <div class="about-value-card__slash"></div>
      </div>

      <div class="about-value-card">
        <div class="about-value-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h3>Precision</h3>
        <p>Millimetres matter. We hold ourselves to exact tolerances because we know your build deserves nothing less.</p>
        <div class="about-value-card__slash"></div>
      </div>

      <div class="about-value-card">
        <div class="about-value-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3>Accountability</h3>
        <p>Every part we sell carries our name. If something isn't right, we make it right — no runaround, no fine print.</p>
        <div class="about-value-card__slash"></div>
      </div>

      <div class="about-value-card">
        <div class="about-value-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3>Performance</h3>
        <p>Our parts are tested in real conditions on real cars. We chase function before aesthetics — but we deliver both.</p>
        <div class="about-value-card__slash"></div>
      </div>

    </div>
  </div>
</div>

<!-- Australia & India Story -->
<div class="about-section about-global full-width">
  <div class="about-global__map">
    <div class="about-global__node about-global__node--au">
      <div class="about-global__node-dot"></div>
      <div class="about-global__node-label">
        <strong>Australia</strong>
        <span>Design · Engineering · QC · Sales</span>
      </div>
    </div>
    <div class="about-global__connector">
      <svg width="160" height="40" viewBox="0 0 160 40" fill="none" aria-hidden="true">
        <path d="M0 20 Q80 0 160 20" stroke="#c60000" stroke-width="1.5" stroke-dasharray="6 4"/>
        <circle cx="160" cy="20" r="4" fill="#c60000"/>
      </svg>
    </div>
    <div class="about-global__node about-global__node--in">
      <div class="about-global__node-dot about-global__node-dot--secondary"></div>
      <div class="about-global__node-label">
        <strong>India</strong>
        <span>Precision Manufacturing · ISO Facilities</span>
      </div>
    </div>
  </div>
  <div class="about-global__text">
    <p class="section-eyebrow">Our Supply Chain</p>
    <h2>Designed Here. Made with Precision There.</h2>
    <p>
      We're proud to partner with world-class manufacturing facilities in India — not as a
      cost-cutting measure, but because they match our engineering rigour. These are ISO-certified
      operations running CNC machining, precision tooling, and multi-stage quality inspection.
    </p>
    <p>
      Our Australian engineering team controls every specification. Our Indian manufacturing
      partners execute it to the letter. The result? Factory-direct quality at a price that
      doesn't punish enthusiasts.
    </p>
  </div>
</div>

<!-- CTA Strip -->
<div class="about-cta full-width">
  <div class="about-cta__slash"></div>
  <div class="about-cta__inner">
    <h2 class="about-cta__heading">Ready to Build Something Great?</h2>
    <p class="about-cta__sub">Browse our range of precision-engineered parts, or reach out — we love talking builds.</p>
    <div class="about-cta__buttons">
      <a href="/collections/all" class="btn btn--primary">Shop All Parts</a>
      <a href="/pages/contact" class="btn btn--ghost">Get in Touch</a>
    </div>
  </div>
</div>

{% stylesheet %}
  /* ── About Hero ── */
  .about-hero {
    position: relative;
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0000 50%, #0a0000 100%);
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .about-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 50%, rgba(198,0,0,0.15) 0%, transparent 60%);
    pointer-events: none;
  }
  .about-hero__ambient {
    position: absolute;
    bottom: -40%;
    right: -10%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(198,0,0,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .about-hero__slash {
    position: absolute;
    right: 8%;
    top: 0; bottom: 0;
    width: 3px;
    background: linear-gradient(180deg, transparent, var(--color-brand) 40%, var(--color-brand) 60%, transparent);
    transform: skewX(-12deg);
    opacity: 0.4;
  }
  .about-hero__slash::before,
  .about-hero__slash::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 1px;
    background: inherit;
    opacity: 0.4;
  }
  .about-hero__slash::before { right: 12px; }
  .about-hero__slash::after  { right: 24px; }

  .about-hero__inner {
    position: relative;
    z-index: 2;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 6rem var(--page-margin);
  }
  .about-hero__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .about-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: var(--color-brand);
  }
  .about-hero__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    color: #fff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  .about-hero__heading-accent {
    color: var(--color-brand);
    display: inline-block;
    position: relative;
  }
  .about-hero__sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.7);
    max-width: 52ch;
    line-height: 1.7;
  }

  /* ── Common section utility ── */
  .about-section {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 3.5rem var(--page-margin);
  }
  .section-eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .section-eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-brand);
  }
  .section-eyebrow--light { color: rgba(255,255,255,0.5); }
  .section-eyebrow--light::before { background: rgba(255,255,255,0.3); }

  /* Diagonal slash accent line */
  .about-slash-line {
    width: 4rem;
    height: 2px;
    background: linear-gradient(90deg, var(--color-brand), transparent);
    margin-bottom: 2.5rem;
    transform: skewX(-20deg);
  }

  /* ── Origin Section ── */
  .about-origin__grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }
  .about-origin__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 1.5rem;
    line-height: 1.15;
    color: var(--color-foreground);
  }
  .about-origin__text p {
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 1rem;
  }
  .about-stat-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .about-stat {
    background: #ffffff;
    border: 1px solid #e8e8e8;
    border-left: 3px solid var(--color-brand);
    border-radius: 4px;
    padding: 1.25rem 1.5rem;
    position: relative;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.05);
  }
  .about-stat::before {
    content: '';
    position: absolute;
    top: 0; right: 0; bottom: 0;
    width: 40%;
    background: radial-gradient(ellipse at right, rgba(198,0,0,0.04), transparent);
  }
  .about-stat__num {
    display: block;
    font-family: var(--font-heading--family);
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--color-brand);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .about-stat__unit {
    font-size: 1.5rem;
    opacity: 0.6;
  }
  .about-stat__label {
    font-size: 0.78rem;
    color: #666666;
    letter-spacing: 0.05em;
  }

  @media (max-width: 768px) {
    .about-origin__grid {
      grid-template-columns: 1fr;
    }
    .about-stat-stack {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .about-stat { flex: 1; min-width: 140px; }
  }

  /* ── Diagonal Quote Section ── */
  .about-diagonal {
    background: linear-gradient(135deg, #0a0a0a 0%, #110000 100%);
    position: relative;
    overflow: hidden;
    padding: 4rem var(--page-margin);
    margin: 3rem 0;
  }
  .about-diagonal__slash {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
      -65deg,
      transparent 0px,
      transparent 40px,
      rgba(198,0,0,0.04) 40px,
      rgba(198,0,0,0.04) 41px
    );
  }
  .about-diagonal__content {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
    text-align: center;
  }
  .about-quote {
    font-family: var(--font-heading--family);
    font-size: clamp(1.2rem, 2.5vw, 1.75rem);
    font-weight: 600;
    color: rgba(255,255,255,0.9);
    line-height: 1.5;
    max-width: 70ch;
    margin: 0 auto 1rem;
    font-style: normal;
    position: relative;
  }
  .about-quote__mark {
    color: var(--color-brand);
    font-size: 2em;
    line-height: 0;
    vertical-align: -0.3em;
    margin: 0 0.1em;
  }
  .about-quote__attr {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }

  /* ── Process Steps ── */
  .about-process__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    margin-bottom: 3rem;
    color: var(--color-foreground);
  }
  .about-process__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 1px solid var(--color-border);
    margin-left: 2rem;
  }
  .about-step {
    display: grid;
    grid-template-columns: 48px 2rem 1fr;
    gap: 0 1.5rem;
    padding: 0 0 3rem;
    align-items: start;
    position: relative;
  }
  .about-step:last-child { padding-bottom: 0; }
  .about-step__num {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 900;
    color: var(--color-brand);
    letter-spacing: 0.05em;
    padding-top: 0.2rem;
    position: relative;
    margin-left: -2.5rem;
    background: var(--color-background);
    padding-right: 0.5rem;
    white-space: nowrap;
  }
  .about-step__slash {
    width: 2px;
    height: 100%;
    background: linear-gradient(180deg, var(--color-brand), transparent);
    transform: skewX(-8deg);
    opacity: 0.4;
    margin-top: 0.3rem;
  }
  .about-step__body h3 {
    font-family: var(--font-heading--family);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-foreground);
    margin-bottom: 0.6rem;
  }
  .about-step__body p {
    color: var(--color-muted);
    line-height: 1.75;
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .about-process__steps { margin-left: 0; border-left: none; }
    .about-step { grid-template-columns: 1fr; }
    .about-step__slash { display: none; }
    .about-step__num { margin-left: 0; padding-right: 0; }
    .about-step { padding-bottom: 2rem; border-bottom: 1px solid var(--color-border); }
  }

  /* ── Values Grid ── */
  .about-values {
    background: linear-gradient(135deg, #0a0a0a, #110000);
    padding: 5rem var(--page-margin);
    position: relative;
    overflow: hidden;
  }
  .about-values::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -65deg,
      transparent 0, transparent 60px,
      rgba(198,0,0,0.03) 60px, rgba(198,0,0,0.03) 61px
    );
  }
  .about-values__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .about-values__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    color: #fff;
    margin-bottom: 3rem;
  }
  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1.5rem;
  }
  .about-value-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-top: 2px solid var(--color-brand);
    border-radius: 4px;
    padding: 2rem 1.5rem;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
  }
  .about-value-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(198,0,0,0.15);
  }
  .about-value-card__slash {
    position: absolute;
    bottom: -10px;
    right: -10px;
    width: 60px;
    height: 60px;
    background: var(--color-brand);
    opacity: 0.06;
    transform: rotate(45deg) skewX(-10deg);
  }
  .about-value-card__icon {
    color: var(--color-brand);
    margin-bottom: 1.25rem;
  }
  .about-value-card h3 {
    font-family: var(--font-heading--family);
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.6rem;
  }
  .about-value-card p {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
  }

  /* ── Global Supply Chain ── */
  .about-global {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-global__map {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background: #111111;
    border: 1px solid rgba(198,0,0,0.2);
    border-top: 3px solid var(--color-brand);
    border-radius: 8px;
    padding: 3rem 2rem;
    position: relative;
    overflow: hidden;
  }
  .about-global__map::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -65deg, transparent 0, transparent 30px,
      rgba(198,0,0,0.04) 30px, rgba(198,0,0,0.04) 31px
    );
  }
  .about-global__node {
    display: flex;
    align-items: center;
    gap: 1rem;
    position: relative;
    z-index: 1;
    width: 100%;
  }
  .about-global__node-dot {
    width: 14px; height: 14px;
    border-radius: 50%;
    background: var(--color-brand);
    box-shadow: 0 0 12px rgba(198,0,0,0.5);
    flex-shrink: 0;
  }
  .about-global__node-dot--secondary {
    background: #666;
    box-shadow: 0 0 8px rgba(100,100,100,0.3);
  }
  .about-global__node-label strong {
    display: block;
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
  }
  .about-global__node-label span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
  }
  .about-global__connector {
    position: relative;
    z-index: 1;
    padding: 0.5rem 0;
    opacity: 0.7;
    align-self: center;
  }
  .about-global__text h2 {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 2.5vw, 2.2rem);
    font-weight: 800;
    color: var(--color-foreground);
    margin-bottom: 1.25rem;
  }
  .about-global__text p {
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  @media (max-width: 768px) {
    .about-global {
      grid-template-columns: 1fr;
    }
  }

  /* ── CTA Strip ── */
  .about-cta {
    background: var(--color-brand);
    position: relative;
    overflow: hidden;
    padding: 4rem var(--page-margin);
    text-align: center;
  }
  .about-cta__slash {
    position: absolute;
    top: 0; left: -5%; right: -5%; bottom: 0;
    background: repeating-linear-gradient(
      -65deg, transparent 0, transparent 50px,
      rgba(0,0,0,0.08) 50px, rgba(0,0,0,0.08) 51px
    );
  }
  .about-cta__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .about-cta__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 900;
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .about-cta__sub {
    color: rgba(255,255,255,0.8);
    margin-bottom: 2rem;
    font-size: 1rem;
  }
  .about-cta__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .about-cta .btn--primary {
    background: #fff;
    color: var(--color-brand);
    border-color: #fff;
  }
  .about-cta .btn--primary:hover {
    background: #f0f0f0;
  }
  .about-cta .btn--ghost {
    border-color: rgba(255,255,255,0.6);
    color: #fff;
  }
  .about-cta .btn--ghost:hover {
    background: rgba(255,255,255,0.15);
    border-color: #fff;
  }
{% endstylesheet %}

