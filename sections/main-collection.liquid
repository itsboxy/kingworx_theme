<section class="collection-page section-padding">

  <!-- Collection Header -->
  <div class="collection-header">
    <div class="collection-header__content">
      {% if collection.image %}
        <div class="collection-header__media">
          <img
            src="{{ collection.image | image_url: width: 1600 }}"
            alt="{{ collection.image.alt | default: collection.title | escape }}"
            loading="eager"
            width="1600"
            height="400"
          >
          <div class="collection-header__media-overlay"></div>
        </div>
      {% endif %}
      <div class="collection-header__text">
        <nav class="breadcrumbs" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span class="breadcrumbs__sep" aria-hidden="true">/</span>
          <a href="{{ routes.collections_url }}">Collections</a>
          <span class="breadcrumbs__sep" aria-hidden="true">/</span>
          <span aria-current="page">{{ collection.title }}</span>
        </nav>
        <h1 class="collection-header__title">{{ collection.title }}</h1>
        {% if collection.description != blank %}
          <p class="collection-header__desc">{{ collection.description }}</p>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="collection-toolbar">
    <div class="collection-toolbar__left">
      <button
        class="btn btn--ghost hide-desktop"
        id="filter-toggle"
        onclick="document.getElementById('filters-panel').classList.toggle('is-open')"
        aria-expanded="false"
        type="button"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
        Filters
      </button>
      <span class="collection-toolbar__count">{{ collection.products_count }} Products</span>
    </div>

    <div class="collection-toolbar__right">
      <select
        class="collection-sort"
        onchange="window.location.href = this.value"
        aria-label="Sort by"
      >
        {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
        {% for option in collection.sort_options %}
          <option
            value="{{ collection.url }}?sort_by={{ option.value }}"
            {% if option.value == sort_by %}selected{% endif %}
          >
            {{ option.name }}
          </option>
        {% endfor %}
      </select>

      <div class="collection-view-toggle">
        <button class="view-btn is-active" data-cols="4" onclick="setGridCols(4, this)" aria-label="4 columns" type="button">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><rect x="0" y="0" width="3" height="3"/><rect x="5" y="0" width="3" height="3"/><rect x="10" y="0" width="3" height="3"/><rect x="13" y="0" width="3" height="3"/><rect x="0" y="5" width="3" height="3"/><rect x="5" y="5" width="3" height="3"/><rect x="10" y="5" width="3" height="3"/><rect x="13" y="5" width="3" height="3"/></svg>
        </button>
        <button class="view-btn" data-cols="2" onclick="setGridCols(2, this)" aria-label="2 columns" type="button">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><rect x="0" y="0" width="7" height="7"/><rect x="9" y="0" width="7" height="7"/><rect x="0" y="9" width="7" height="7"/><rect x="9" y="9" width="7" height="7"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div class="collection-layout">

    <!-- Filters Sidebar (desktop) -->
    {% if section.settings.show_filters %}
      <aside
        class="collection-filters"
        id="filters-panel"
        aria-label="Product filters"
      >
        <div class="collection-filters__header">
          <h3>Filter</h3>
          <button
            class="collection-filters__close hide-desktop"
            onclick="document.getElementById('filters-panel').classList.remove('is-open')"
            type="button"
            aria-label="Close filters"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>

        {% for filter in collection.filters %}
          <div class="filter-group">
            <div class="filter-group__title" onclick="this.closest('.filter-group').classList.toggle('is-collapsed')">
              {{ filter.label }}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            </div>
            <div class="filter-group__body">
              {% for filter_value in filter.values %}
                <label class="filter-option">
                  <input
                    type="checkbox"
                    name="{{ filter.param_name }}"
                    value="{{ filter_value.value }}"
                    {% if filter_value.active %}checked{% endif %}
                    onchange="applyFilters()"
                    id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                  >
                  {{ filter_value.label }}
                  <span class="filter-count">({{ filter_value.count }})</span>
                </label>
              {% endfor %}
            </div>
          </div>
        {% endfor %}

        {% if collection.filters.size == 0 %}
          {% comment %} Placeholder for stores without filters set up {% endcomment %}
          <div class="filter-group">
            <div class="filter-group__title">Availability</div>
            <div class="filter-group__body">
              <label class="filter-option">
                <input type="checkbox"> In Stock
              </label>
              <label class="filter-option">
                <input type="checkbox"> Pre-Order
              </label>
            </div>
          </div>
        {% endif %}
      </aside>
    {% endif %}

    <!-- Products -->
    <div class="collection-products">
      {% paginate collection.products by section.settings.products_per_page %}
        {% if collection.products.size > 0 %}
          <div class="product-grid" id="collection-product-grid">
            {% for product in collection.products %}
              {% render 'product-card', product: product %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="pagination" aria-label="Pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="pagination__item" aria-label="Previous page">&lsaquo;</a>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
                {% else %}
                  {% if part.title == paginate.current_page %}
                    <span class="pagination__item pagination__item--active" aria-current="page">{{ part.title }}</span>
                  {% else %}
                    <span class="pagination__item">{{ part.title }}</span>
                  {% endif %}
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="pagination__item" aria-label="Next page">&rsaquo;</a>
              {% endif %}
            </nav>
          {% endif %}
        {% else %}
          <div class="collection-empty">
            <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            <h3>No products found</h3>
            <p>Try adjusting your filters or browsing all products.</p>
            <a href="{{ routes.collections_url }}" class="btn btn--ghost">Browse All</a>
          </div>
        {% endif %}
      {% endpaginate %}
    </div>

  </div>

</section>

<script>
  function setGridCols(cols, btn) {
    document.getElementById('collection-product-grid').style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';
    document.querySelectorAll('.view-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
  }

  function applyFilters() {
    // Collect checked filter values and reload page with params
    var params = new URLSearchParams(window.location.search);
    var checkboxes = document.querySelectorAll('.filter-group__body input[type="checkbox"]:checked');
    var filters = {};
    checkboxes.forEach(function(cb) {
      if (!filters[cb.name]) filters[cb.name] = [];
      filters[cb.name].push(cb.value);
    });
    // Clear existing filter params and re-add
    var newUrl = window.location.pathname;
    var parts = [];
    for (var key in filters) {
      filters[key].forEach(function(val) { parts.push(encodeURIComponent(key) + '=' + encodeURIComponent(val)); });
    }
    window.location.href = newUrl + (parts.length ? '?' + parts.join('&') : '');
  }
</script>

{% stylesheet %}
  .collection-page {
    padding: 0 var(--page-margin) var(--spacing-2xl);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  /* Collection header */
  .collection-header {
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-cards);
    margin-bottom: var(--spacing-lg);
    min-height: 180px;
    display: flex;
    align-items: flex-end;
  }

  .collection-header__content {
    position: relative;
    width: 100%;
  }

  .collection-header__media {
    position: absolute;
    inset: 0;
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
  }

  .collection-header__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-header__media-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 100%);
  }

  .collection-header__text {
    position: relative;
    z-index: 1;
    padding: var(--spacing-lg);
    padding-top: var(--spacing-lg);
  }

  .collection-header__title {
    font-size: clamp(1.8rem, 4vw, 3.5rem);
    margin: 0.5rem 0;
  }

  .collection-header__desc {
    font-size: 0.9rem;
    max-width: 60ch;
    margin: 0;
    color: rgba(255,255,255,0.65);
  }

  /* Toolbar */
  .collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-lg);
    gap: 1rem;
  }

  .collection-toolbar__left,
  .collection-toolbar__right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .collection-toolbar__count {
    font-family: var(--font-heading--family);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .collection-sort {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-foreground);
    font-family: var(--font-heading--family);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.5rem 0.85rem;
    cursor: pointer;
    outline: none;
  }

  .collection-view-toggle {
    display: flex;
    gap: 0.25rem;
  }

  .view-btn {
    width: 2rem;
    height: 2rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 3px;
    color: var(--color-muted);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .view-btn.is-active,
  .view-btn:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
  }

  /* Layout */
  .collection-layout {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--spacing-lg);
    align-items: start;
  }

  @media (max-width: 900px) {
    .collection-layout { grid-template-columns: 1fr; }
  }

  /* Filters */
  .collection-filters {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-cards);
    padding: 1.25rem;
    position: sticky;
    top: calc(var(--header-height) + 1rem);
  }

  @media (max-width: 900px) {
    .collection-filters {
      position: fixed;
      top: 0;
      left: 0;
      height: 100%;
      width: min(320px, 100vw);
      z-index: 1000;
      border-radius: 0;
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform var(--transition-slow);
    }

    .collection-filters.is-open {
      transform: translateX(0);
    }
  }

  .collection-filters__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
  }

  .collection-filters__header h3 {
    font-size: 0.85rem;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .collection-filters__close {
    background: none;
    border: none;
    color: var(--color-muted);
    cursor: pointer;
    padding: 0;
    transition: color var(--transition-fast);
  }

  .collection-filters__close:hover { color: var(--color-brand); }

  .filter-count {
    color: var(--color-muted);
    font-size: 0.75rem;
    margin-left: auto;
  }

  /* Empty state */
  .collection-empty {
    text-align: center;
    padding: var(--spacing-2xl) var(--spacing-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .collection-empty svg { color: var(--color-border); }
  .collection-empty h3 { font-size: 1.5rem; margin: 0; }
  .collection-empty p { color: var(--color-muted); margin: 0; }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters sidebar",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    }
  ]
}
{% endschema %}
