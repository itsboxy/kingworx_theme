<section class="collection-page">

  <!-- Collection Header -->
  <div class="collection-header">
    {% if collection.image %}
      <img
        src="{{ collection.image | image_url: width: 1600 }}"
        alt="{{ collection.image.alt | default: collection.title | escape }}"
        loading="eager"
        width="1600"
        height="400"
        class="collection-header__img"
      >
    {% endif %}
    <div class="collection-header__overlay"></div>
    <div class="collection-header__bg-text" aria-hidden="true">{{ collection.title }}</div>
    <div class="collection-header__text">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Home</a>
        <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        <a href="{{ routes.collections_url }}">Collections</a>
        <span class="breadcrumbs__sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ collection.title }}</span>
      </nav>
      <h1 class="collection-header__title">{{ collection.title }}</h1>
      {% if collection.description != blank %}
        <p class="collection-header__desc">{{ collection.description }}</p>
      {% endif %}
    </div>
  </div>

  <!-- Body -->
  <div class="collection-body">

    <!-- Toolbar -->
    <div class="collection-toolbar">
      <div class="collection-toolbar__left">
        <button
          class="filter-toggle-btn"
          id="filter-toggle"
          onclick="document.getElementById('filters-panel').classList.toggle('is-open')"
          type="button"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
          Filters
        </button>
        <span class="collection-toolbar__count">{{ collection.products_count }} Products</span>
      </div>
      <div class="collection-toolbar__right">
        <select class="collection-sort" onchange="window.location.href = this.value" aria-label="Sort by">
          {% assign sort_by = collection.sort_by | default: collection.default_sort_by %}
          {% for option in collection.sort_options %}
            <option value="{{ collection.url }}?sort_by={{ option.value }}" {% if option.value == sort_by %}selected{% endif %}>
              {{ option.name }}
            </option>
          {% endfor %}
        </select>
        <div class="collection-view-toggle">
          <button class="view-btn is-active" data-cols="4" onclick="setGridCols(4, this)" aria-label="4 columns" type="button">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><rect x="0" y="0" width="3" height="3"/><rect x="5" y="0" width="3" height="3"/><rect x="10" y="0" width="3" height="3"/><rect x="13" y="0" width="3" height="3"/><rect x="0" y="5" width="3" height="3"/><rect x="5" y="5" width="3" height="3"/><rect x="10" y="5" width="3" height="3"/><rect x="13" y="5" width="3" height="3"/></svg>
          </button>
          <button class="view-btn" data-cols="2" onclick="setGridCols(2, this)" aria-label="2 columns" type="button">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><rect x="0" y="0" width="7" height="7"/><rect x="9" y="0" width="7" height="7"/><rect x="0" y="9" width="7" height="7"/><rect x="9" y="9" width="7" height="7"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- Content: Sidebar + Grid -->
    <div class="collection-layout">

      <!-- Filters Sidebar -->
      {% if section.settings.show_filters %}
        <aside class="collection-filters" id="filters-panel" aria-label="Product filters">
          <div class="collection-filters__header">
            <h3 class="collection-filters__title">Filter</h3>
            <button class="collection-filters__close hide-desktop" onclick="document.getElementById('filters-panel').classList.remove('is-open')" type="button" aria-label="Close filters">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
          </div>

          {% for filter in collection.filters %}
            <div class="filter-group">
              <button class="filter-group__title" onclick="this.closest('.filter-group').classList.toggle('is-collapsed')" type="button">
                {{ filter.label }}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="filter-group__body">
                {% for filter_value in filter.values %}
                  <label class="filter-option">
                    <input
                      type="checkbox"
                      name="{{ filter.param_name }}"
                      value="{{ filter_value.value }}"
                      {% if filter_value.active %}checked{% endif %}
                      onchange="applyFilters()"
                      id="filter-{{ filter.param_name }}-{{ forloop.index }}"
                    >
                    <span class="filter-option__label">{{ filter_value.label }}</span>
                    <span class="filter-count">{{ filter_value.count }}</span>
                  </label>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          {% if collection.filters.size == 0 %}
            <div class="filter-group">
              <button class="filter-group__title" onclick="this.closest('.filter-group').classList.toggle('is-collapsed')" type="button">
                Availability
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
              </button>
              <div class="filter-group__body">
                <label class="filter-option"><input type="checkbox"><span class="filter-option__label">In Stock</span></label>
                <label class="filter-option"><input type="checkbox"><span class="filter-option__label">Pre-Order</span></label>
              </div>
            </div>
          {% endif %}
        </aside>
      {% endif %}

      <!-- Products -->
      <div class="collection-products">
        {% paginate collection.products by section.settings.products_per_page %}
          {% if collection.products.size > 0 %}
            <div class="product-grid" id="collection-product-grid">
              {% for product in collection.products %}
                {% render 'product-card', product: product %}
              {% endfor %}
            </div>

            {% if paginate.pages > 1 %}
              <nav class="pagination" aria-label="Pagination">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="pagination__item" aria-label="Previous page">&lsaquo;</a>
                {% endif %}
                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="pagination__item">{{ part.title }}</a>
                  {% else %}
                    {% if part.title == paginate.current_page %}
                      <span class="pagination__item pagination__item--active" aria-current="page">{{ part.title }}</span>
                    {% else %}
                      <span class="pagination__item">{{ part.title }}</span>
                    {% endif %}
                  {% endif %}
                {% endfor %}
                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="pagination__item" aria-label="Next page">&rsaquo;</a>
                {% endif %}
              </nav>
            {% endif %}

          {% else %}
            <div class="collection-empty">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
              <h3>No products found</h3>
              <p>Try adjusting your filters or browse all products.</p>
              <a href="{{ routes.collections_url }}" class="btn btn--ghost">Browse All</a>
            </div>
          {% endif %}
        {% endpaginate %}
      </div>

    </div>
  </div>

</section>

<script>
  function setGridCols(cols, btn) {
    document.getElementById('collection-product-grid').style.gridTemplateColumns = 'repeat(' + cols + ', 1fr)';
    document.querySelectorAll('.view-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
  }

  function applyFilters() {
    var checkboxes = document.querySelectorAll('.filter-group__body input[type="checkbox"]:checked');
    var filters = {};
    checkboxes.forEach(function(cb) {
      if (!filters[cb.name]) filters[cb.name] = [];
      filters[cb.name].push(cb.value);
    });
    var newUrl = window.location.pathname;
    var parts = [];
    for (var key in filters) {
      filters[key].forEach(function(val) { parts.push(encodeURIComponent(key) + '=' + encodeURIComponent(val)); });
    }
    window.location.href = newUrl + (parts.length ? '?' + parts.join('&') : '');
  }
</script>

{% stylesheet %}

  /* ── Page wrapper ── */
  .collection-page {
    background: #ffffff;
    min-height: 100vh;
  }

  /* ── Collection header — full-bleed ── */
  .collection-header {
    position: relative;
    min-height: 280px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: #0a0a0a;
    border-bottom: 3px solid var(--color-brand);
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }

  /* Red left-side vertical bar */
  .collection-header::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 5px;
    height: 100%;
    background: var(--color-brand);
    z-index: 4;
  }

  /* Diagonal slash lines across full header */
  .collection-header::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      -60deg,
      transparent,
      transparent 40px,
      rgba(198,0,0,0.07) 40px,
      rgba(198,0,0,0.07) 42px
    );
    z-index: 1;
  }

  .collection-header__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .collection-header__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, rgba(0,0,0,0.97) 0%, rgba(0,0,0,0.75) 50%, rgba(0,0,0,0.4) 100%);
    z-index: 2;
  }

  /* Ghost background title */
  .collection-header__bg-text {
    position: absolute;
    right: -0.02em;
    bottom: -0.18em;
    font-family: var(--font-heading--family);
    font-size: clamp(7rem, 18vw, 18rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: transparent;
    -webkit-text-stroke: 1px rgba(255,255,255,0.07);
    line-height: 1;
    pointer-events: none;
    user-select: none;
    z-index: 2;
    white-space: nowrap;
  }

  .collection-header__text {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 2.5rem var(--page-margin);
  }

  .collection-header__title {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: #fff;
    margin: 0.5rem 0 0;
    line-height: 1;
    display: inline-block;
    padding-bottom: 0.4rem;
    border-bottom: 3px solid var(--color-brand);
  }

  .collection-header__desc {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.55);
    margin: 0.75rem 0 0;
    max-width: 55ch;
  }

  /* Breadcrumbs */
  .breadcrumbs {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 0.25rem;
  }
  .breadcrumbs a { color: rgba(255,255,255,0.5); transition: color var(--transition-fast); }
  .breadcrumbs a:hover { color: var(--color-brand); }
  .breadcrumbs__sep { color: rgba(255,255,255,0.25); }

  /* ── Body (toolbar + layout) ── */
  .collection-body {
    padding: 1.5rem var(--page-margin) 4rem;
    max-width: var(--page-width);
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  /* ── Toolbar ── */
  .collection-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    border-bottom: 2px solid var(--color-brand);
    margin-bottom: 1.5rem;
    gap: 1rem;
  }

  .collection-toolbar__left,
  .collection-toolbar__right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .collection-toolbar__count {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #888888;
  }

  .filter-toggle-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #444;
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.55rem 1rem;
    cursor: pointer;
    transition: all var(--transition-fast);
  }
  .filter-toggle-btn:hover { border-color: var(--color-brand); color: var(--color-brand); }

  .collection-sort {
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #333;
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.55rem 0.85rem;
    cursor: pointer;
    outline: none;
    transition: border-color var(--transition-fast);
  }
  .collection-sort:hover, .collection-sort:focus { border-color: var(--color-brand); }
  .collection-sort option { background: #fff; color: #111; }

  .collection-view-toggle { display: flex; gap: 0.25rem; }

  .view-btn {
    width: 2rem;
    height: 2rem;
    background: #fff;
    border: 1px solid #d0d0d0;
    border-radius: 3px;
    color: #999;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }
  .view-btn.is-active, .view-btn:hover {
    background: var(--color-brand);
    border-color: var(--color-brand);
    color: #fff;
  }

  /* ── Layout: full-width product grid on desktop ── */
  .collection-layout {
    display: block;
    width: 100%;
  }

  /* ── Filters sidebar — always a drawer (slide in from left) ── */
  .collection-filters {
    display: block;
    position: fixed;
    top: 0; left: 0;
    height: 100%; width: min(300px, 100vw);
    z-index: 1000;
    background: #ffffff;
    border-radius: 0;
    border-right: 3px solid var(--color-brand);
    padding: 1.5rem;
    overflow-y: auto;
    transform: translateX(-110%);
    transition: transform var(--transition-slow);
    box-shadow: 4px 0 24px rgba(0,0,0,0.15);
  }
  .collection-filters.is-open { transform: translateX(0); }

  .collection-filters__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--color-brand);
  }

  .collection-filters__title {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #111111;
    margin: 0;
  }

  .collection-filters__close {
    background: none;
    border: none;
    color: #999;
    cursor: pointer;
    padding: 0;
    transition: color var(--transition-fast);
  }
  .collection-filters__close:hover { color: var(--color-brand); }

  .filter-group {
    border-bottom: 1px solid #f0f0f0;
    padding-bottom: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .filter-group:last-child { border-bottom: none; margin-bottom: 0; }

  .filter-group__title {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    padding: 0.5rem 0;
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #111111;
    cursor: pointer;
    transition: color var(--transition-fast);
  }
  .filter-group__title:hover { color: var(--color-brand); }
  .filter-group__title svg { transition: transform var(--transition-fast); flex-shrink: 0; }
  .filter-group.is-collapsed .filter-group__title svg { transform: rotate(-90deg); }

  .filter-group__body {
    padding: 0.5rem 0 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .filter-group.is-collapsed .filter-group__body { display: none; }

  .filter-option {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    padding: 0.2rem 0;
  }
  .filter-option input[type="checkbox"] {
    width: 14px;
    height: 14px;
    accent-color: var(--color-brand);
    cursor: pointer;
    flex-shrink: 0;
    border-radius: 2px;
  }
  .filter-option__label {
    font-size: 0.8rem;
    color: #555555;
    transition: color var(--transition-fast);
    flex: 1;
  }
  .filter-option:hover .filter-option__label { color: var(--color-brand); }

  .filter-count {
    font-family: var(--font-heading--family);
    font-size: 0.65rem;
    font-weight: 700;
    color: #999;
    background: #f0f0f0;
    padding: 0.1rem 0.45rem;
    border-radius: 20px;
  }

  /* ── Product grid ── */
  .collection-products {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
  }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    width: 100%;
    flex: 1;
  }

  @media (max-width: 1400px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px)  { .product-grid { grid-template-columns: 1fr; } }

  /* ── Empty state ── */
  .collection-empty {
    text-align: center;
    padding: 5rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: #ccc;
  }
  .collection-empty h3 { font-size: 1.4rem; color: #333; margin: 0; }
  .collection-empty p  { color: #888; margin: 0; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .collection-body { padding: 0 var(--page-margin) 3rem; }

    .collection-filters {
      display: block;
      position: fixed;
      top: 0; left: 0;
      height: 100%; width: min(300px, 100vw);
      z-index: 1000;
      background: #ffffff;
      border-radius: 0;
      padding: 1.5rem;
      overflow-y: auto;
      transform: translateX(-110%);
      transition: transform var(--transition-slow);
      box-shadow: 4px 0 24px rgba(0,0,0,0.15);
    }
    .collection-filters.is-open { transform: translateX(0); }
  }

  @media (max-width: 600px) {
    .collection-header__text { padding: 2rem 1.25rem; }
    .collection-toolbar { flex-wrap: wrap; }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filters sidebar",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 12,
      "max": 48,
      "step": 4,
      "label": "Products per page",
      "default": 24
    }
  ]
}
{% endschema %}
