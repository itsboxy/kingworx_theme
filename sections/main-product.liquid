{% assign current_variant = product.selected_or_first_available_variant %}

<div class="pd full-width">

  <!-- ══ Breadcrumb bar ══ -->
  <div class="pd-crumb full-width">
    <div class="pd-crumb__inner">
      <a href="{{ routes.root_url }}">Home</a>
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true"><path d="M3 1l4 4-4 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      {% endif %}
      <span aria-current="page">{{ product.title }}</span>
    </div>
  </div>

  <!-- ══ Main content ══ -->
  <div class="pd__wrap">
    <div class="pd__grid">

      <!-- ── Gallery column ── -->
      <div class="pd-gallery">

        <div class="pd-gallery__stage" id="pd-stage">
          {% if product.images.size > 0 %}
            <img
              id="pd-main-img"
              src="{{ product.images.first | image_url: width: 1400 }}"
              alt="{{ product.images.first.alt | default: product.title | escape }}"
              loading="eager"
              width="1400"
              height="1400"
            >
          {% else %}
            <div class="pd-gallery__empty">
              <svg viewBox="0 0 200 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M20 150 L60 80 L98 118 L130 60 L180 150Z" fill="#222" stroke="#c60000" stroke-width="1"/>
                <circle cx="152" cy="55" r="16" fill="#222" stroke="#c60000" stroke-width="1"/>
              </svg>
            </div>
          {% endif %}
          <div class="pd-gallery__glow" aria-hidden="true"></div>
        </div>

        {% if product.images.size > 1 %}
          <div class="pd-gallery__rail">
            {% for image in product.images %}
              <button
                class="pd-gallery__thumb {% if forloop.first %}is-active{% endif %}"
                onclick="pdSetImage('{{ image | image_url: width: 1400 }}', this)"
                type="button"
                aria-label="View image {{ forloop.index }}"
              >
                <img
                  src="{{ image | image_url: width: 160 }}"
                  alt="{{ image.alt | default: product.title | escape }}"
                  loading="lazy"
                  width="160"
                  height="160"
                >
              </button>
            {% endfor %}
          </div>
        {% endif %}

        <!-- Fitment badge -->
        <div class="pd-fitment">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          CAD-Engineered for Precise Fitment
        </div>

      </div>

      <!-- ── Info column ── -->
      <div class="pd-info">

        <!-- Vendor + title -->
        {% if product.vendor != blank %}
          <a href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_encode }}" class="pd-info__vendor">
            <span class="pd-info__vendor-line"></span>
            {{ product.vendor }}
          </a>
        {% endif %}

        <h1 class="pd-info__title">{{ product.title }}</h1>

        {% if product.metafields.reviews.rating != blank %}
          <div class="pd-info__rating" aria-label="{{ product.metafields.reviews.rating.value }} out of 5 stars">
            <div class="stars" style="--rating: {{ product.metafields.reviews.rating.value }}" aria-hidden="true"></div>
            {% if product.metafields.reviews.rating_count != blank %}
              <span>({{ product.metafields.reviews.rating_count.value }} reviews)</span>
            {% endif %}
          </div>
        {% endif %}

        <!-- Price -->
        <div class="pd-price" id="pd-price">
          <div class="pd-price__row">
            <span class="pd-price__now">{{ current_variant.price | money }}</span>
            {% if current_variant.compare_at_price > current_variant.price %}
              <span class="pd-price__was">{{ current_variant.compare_at_price | money }}</span>
              {% assign saving = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
              <span class="pd-price__save">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Save {{ saving }}%
              </span>
            {% endif %}
          </div>
          <div class="pd-price__availability {% if current_variant.available %}pd-price__availability--in{% else %}pd-price__availability--out{% endif %}">
            <span class="pd-price__avail-dot"></span>
            {% if current_variant.available %}In Stock{% else %}Out of Stock{% endif %}
          </div>
        </div>

        <!-- Short description -->
        {% if product.metafields.custom.short_description != blank %}
          <p class="pd-info__short-desc">{{ product.metafields.custom.short_description }}</p>
        {% endif %}

        <!-- Divider -->
        <div class="pd-divider" aria-hidden="true"></div>

        <!-- Variants -->
        {% unless product.has_only_default_variant %}
          <div class="pd-variants">
            {% for option in product.options_with_values %}
              <div class="pd-option">
                <div class="pd-option__label">
                  <span>{{ option.name }}</span>
                  <span class="pd-option__selected" id="pd-sel-{{ option.name | handleize }}">{{ option.selected_value }}</span>
                </div>
                <div class="pd-option__btns">
                  {% for value in option.values %}
                    <button
                      class="pd-opt-btn {% if option.selected_value == value %}is-active{% endif %}"
                      onclick="pdSelectOption(this, '{{ option.name | handleize }}', '{{ value | escape }}')"
                      type="button"
                    >{{ value }}</button>
                  {% endfor %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endunless %}

        <!-- Add to cart form -->
        <form method="post" action="/cart/add" id="pd-form-{{ product.id }}" class="pd-form">
          <input type="hidden" name="id" id="pd-variant-id" value="{{ current_variant.id }}">
          <input type="hidden" name="quantity" id="pd-qty-hidden" value="1">

          <div class="pd-form__row">
            <div class="pd-qty">
              <button type="button" class="pd-qty__btn" onclick="pdQty(-1)" aria-label="Decrease">−</button>
              <input
                type="number"
                id="pd-qty-input"
                class="pd-qty__input"
                value="1" min="1"
                onchange="document.getElementById('pd-qty-hidden').value=this.value"
                aria-label="Quantity"
              >
              <button type="button" class="pd-qty__btn" onclick="pdQty(1)" aria-label="Increase">+</button>
            </div>

            <button
              type="submit"
              id="pd-atc"
              class="btn btn--primary btn--large pd-form__atc"
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
              {% if current_variant.available %}Add to Cart{% else %}Sold Out{% endif %}
            </button>
          </div>

          {% if current_variant.available %}
            <button type="button" class="pd-form__buy-now" onclick="pdBuyNow()">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Buy Now — Instant Checkout
            </button>
          {% endif %}
        </form>

        <!-- Trust row -->
        <div class="pd-trust">
          <div class="pd-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>Secure Checkout</span>
          </div>
          <div class="pd-trust__sep" aria-hidden="true"></div>
          <div class="pd-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>AU-Wide Shipping</span>
          </div>
          <div class="pd-trust__sep" aria-hidden="true"></div>
          <div class="pd-trust__item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            <span>30-Day Returns</span>
          </div>
        </div>

        <!-- Meta -->
        <div class="pd-meta">
          {% if product.vendor != blank %}
            <div class="pd-meta__row"><span>Brand</span><span>{{ product.vendor }}</span></div>
          {% endif %}
          {% if product.sku != blank %}
            <div class="pd-meta__row"><span>SKU</span><span>{{ current_variant.sku }}</span></div>
          {% endif %}
          {% if product.type != blank %}
            <div class="pd-meta__row"><span>Type</span><span>{{ product.type }}</span></div>
          {% endif %}
          {% if product.tags.size > 0 %}
            <div class="pd-meta__row">
              <span>Tags</span>
              <span class="pd-meta__tags">
                {% for tag in product.tags limit: 5 %}
                  <a href="{{ routes.collections_url }}/all?q={{ tag | url_encode }}" class="pd-meta__tag">{{ tag }}</a>
                {% endfor %}
              </span>
            </div>
          {% endif %}
        </div>

      </div><!-- /pd-info -->
    </div><!-- /pd__grid -->

    <!-- ══ Tabs — full width below grid ══ -->
    <div class="pd-tabs">
      <div class="pd-tabs__nav" role="tablist">
        <button class="pd-tab-btn is-active" onclick="pdTab(this,'pd-tab-desc')" type="button" role="tab" aria-selected="true">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          Description
        </button>
        <button class="pd-tab-btn" onclick="pdTab(this,'pd-tab-specs')" type="button" role="tab" aria-selected="false">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          Specifications
        </button>
        <button class="pd-tab-btn" onclick="pdTab(this,'pd-tab-ship')" type="button" role="tab" aria-selected="false">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Shipping & Returns
        </button>
      </div>

      <div class="pd-tabs__body">
        <div id="pd-tab-desc" class="pd-tab-panel is-active" role="tabpanel">
          {% if product.description != blank %}
            <div class="pd-rte">{{ product.description }}</div>
          {% else %}
            <p class="pd-tab-panel__empty">No description available yet.</p>
          {% endif %}
        </div>

        <div id="pd-tab-specs" class="pd-tab-panel" role="tabpanel">
          {% if product.metafields.custom.specifications != blank %}
            <div class="pd-rte">{{ product.metafields.custom.specifications }}</div>
          {% else %}
            <p class="pd-tab-panel__empty">Detailed specifications coming soon. Contact us for fitment queries.</p>
          {% endif %}
        </div>

        <div id="pd-tab-ship" class="pd-tab-panel" role="tabpanel">
          <div class="pd-ship">
            <div class="pd-ship__card">
              <div class="pd-ship__card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              </div>
              <h4>Delivery</h4>
              <ul>
                <li>Standard shipping — 3 to 7 business days</li>
                <li>Express shipping — 1 to 3 business days</li>
                <li>Free standard shipping on orders over $150</li>
                <li>Dispatched from our Australian warehouse</li>
              </ul>
            </div>
            <div class="pd-ship__card">
              <div class="pd-ship__card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
              </div>
              <h4>Returns</h4>
              <ul>
                <li>30-day returns on unused, uninstalled parts</li>
                <li>Original packaging required</li>
                <li>No restocking fees on defective items</li>
                <li><a href="/policies/refund-policy">Full return policy &rarr;</a></li>
              </ul>
            </div>
            <div class="pd-ship__card">
              <div class="pd-ship__card-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              </div>
              <h4>Warranty</h4>
              <ul>
                <li>12-month manufacturing defect warranty</li>
                <li>Covers fitment issues on verified applications</li>
                <li>Contact us within 7 days of receipt for claims</li>
                <li><a href="/pages/contact">Contact support &rarr;</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ══ Related Products ══ -->
    {% if section.settings.show_related and product.collections.first %}
      <div class="pd-related">
        <div class="pd-related__header">
          <p class="pd-related__eyebrow">
            <span></span>
            You May Also Like
          </p>
          <h2 class="pd-related__heading">Related Parts</h2>
        </div>
        <div class="product-grid">
          {% assign related_collection = product.collections.first %}
          {% for related_product in related_collection.products limit: 4 %}
            {% unless related_product.id == product.id %}
              {% render 'product-card', product: related_product %}
            {% endunless %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div><!-- /pd__wrap -->
</div><!-- /pd -->

<script>
  function pdQty(delta) {
    var input = document.getElementById('pd-qty-input');
    var val = Math.max(1, (parseInt(input.value) || 1) + delta);
    input.value = val;
    document.getElementById('pd-qty-hidden').value = val;
  }

  function pdSetImage(src, btn) {
    var img = document.getElementById('pd-main-img');
    if (!img) return;
    img.style.opacity = '0';
    setTimeout(function() { img.src = src; img.style.opacity = '1'; }, 140);
    btn.closest('.pd-gallery__rail').querySelectorAll('.pd-gallery__thumb').forEach(function(t) { t.classList.remove('is-active'); });
    btn.classList.add('is-active');
  }

  function pdTab(btn, panelId) {
    var tabs = btn.closest('.pd-tabs');
    tabs.querySelectorAll('.pd-tab-btn').forEach(function(b) { b.classList.remove('is-active'); b.setAttribute('aria-selected','false'); });
    tabs.querySelectorAll('.pd-tab-panel').forEach(function(p) { p.classList.remove('is-active'); });
    btn.classList.add('is-active');
    btn.setAttribute('aria-selected','true');
    document.getElementById(panelId).classList.add('is-active');
  }

  function pdSelectOption(btn, optName, val) {
    btn.closest('.pd-option').querySelectorAll('.pd-opt-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.classList.add('is-active');
    var label = document.getElementById('pd-sel-' + optName);
    if (label) label.textContent = val;
  }

  function pdBuyNow() {
    var id = document.getElementById('pd-variant-id').value;
    var qty = document.getElementById('pd-qty-input').value;
    window.location.href = '/cart/' + id + ':' + qty + '?checkout=true';
  }
</script>

{% stylesheet %}

/* ══════════════════════════════
   Product Page — KingWorX Theme
   ══════════════════════════════ */

.pd {
  background: var(--color-background);
}

.pd__wrap {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0 var(--page-margin) var(--spacing-2xl);
}

/* ── Breadcrumb ── */
.pd-crumb {
  background: var(--color-surface);
  border-bottom: 1px solid var(--color-border);
}
.pd-crumb__inner {
  max-width: var(--page-width);
  margin: 0 auto;
  padding: 0.8rem var(--page-margin);
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.775rem;
  color: var(--color-muted);
}
.pd-crumb__inner svg { opacity: 0.4; flex-shrink: 0; }
.pd-crumb__inner a { color: var(--color-muted); transition: color var(--transition-fast); }
.pd-crumb__inner a:hover { color: var(--color-brand); }
.pd-crumb__inner span[aria-current] { color: var(--color-foreground); }

/* ── Grid ── */
.pd__grid {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: var(--spacing-xl);
  padding-top: var(--spacing-lg);
  align-items: start;
}
@media (max-width: 900px) {
  .pd__grid { grid-template-columns: 1fr; gap: var(--spacing-lg); }
}

/* ══ Gallery ══ */
.pd-gallery {
  position: sticky;
  top: calc(var(--header-height) + 1.5rem);
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}
@media (max-width: 900px) { .pd-gallery { position: static; } }

.pd-gallery__stage {
  position: relative;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 4 / 3;
  max-height: 520px;
  cursor: zoom-in;
}
.pd-gallery__stage::before {
  content: '';
  position: absolute;
  bottom: 0; right: 0;
  width: 50%;
  height: 50%;
  background: radial-gradient(ellipse at bottom right, rgba(198,0,0,0.07) 0%, transparent 70%);
  pointer-events: none;
  z-index: 1;
}
.pd-gallery__stage img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: opacity 0.14s ease, transform 0.4s ease;
}
.pd-gallery__stage:hover img { transform: scale(1.05); }
.pd-gallery__glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 80% 90%, rgba(198,0,0,0.05) 0%, transparent 55%);
  pointer-events: none;
  z-index: 2;
}
.pd-gallery__empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pd-gallery__empty svg { width: 80px; height: 80px; opacity: 0.3; }

.pd-gallery__rail {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
}
.pd-gallery__thumb {
  width: 72px;
  height: 72px;
  border: 2px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  padding: 0;
  background: var(--color-surface);
  flex-shrink: 0;
  transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
}
.pd-gallery__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
.pd-gallery__thumb.is-active { border-color: var(--color-brand); box-shadow: 0 0 0 3px rgba(198,0,0,0.2); }
.pd-gallery__thumb:hover:not(.is-active) { border-color: var(--color-foreground); }

.pd-fitment {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-muted);
  padding: 0.65rem 1rem;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-left: 3px solid var(--color-brand);
  border-radius: 4px;
}
.pd-fitment svg { color: var(--color-brand); flex-shrink: 0; }

/* ══ Info column ══ */
.pd-info {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.pd-info__vendor {
  display: inline-flex;
  align-items: center;
  gap: 0.6rem;
  font-family: var(--font-heading--family);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--color-brand);
  margin-bottom: 0.65rem;
  transition: opacity var(--transition-fast);
}
.pd-info__vendor:hover { opacity: 0.75; }
.pd-info__vendor-line {
  display: block;
  width: 2rem;
  height: 2px;
  background: var(--color-brand);
  flex-shrink: 0;
}

.pd-info__title {
  font-family: var(--font-heading--family);
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  font-weight: 900;
  line-height: 1.0;
  color: var(--color-foreground);
  text-transform: uppercase;
  letter-spacing: 0.02em;
  margin-bottom: 0.75rem;
}

.pd-info__rating {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.78rem;
  color: var(--color-muted);
  margin-bottom: 1rem;
}

/* ── Price ── */
.pd-price {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 2px solid var(--color-brand);
  border-radius: 6px;
  padding: 1.25rem 1.5rem;
  margin-bottom: 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.pd-price__row {
  display: flex;
  align-items: baseline;
  gap: 0.75rem;
  flex-wrap: wrap;
}
.pd-price__now {
  font-family: var(--font-heading--family);
  font-size: clamp(2rem, 3.5vw, 2.75rem);
  font-weight: 900;
  color: var(--color-foreground);
  line-height: 1;
}
.pd-price__was {
  font-size: 1rem;
  color: var(--color-muted);
  text-decoration: line-through;
}
.pd-price__save {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  background: var(--color-brand);
  color: #fff;
  font-family: var(--font-heading--family);
  font-size: 0.65rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.3rem 0.65rem;
  border-radius: 3px;
  box-shadow: 0 2px 10px rgba(198,0,0,0.4);
  align-self: center;
}
.pd-price__availability {
  display: flex;
  align-items: center;
  gap: 0.45rem;
  font-family: var(--font-heading--family);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
}
.pd-price__avail-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}
.pd-price__availability--in { color: #4caf50; }
.pd-price__availability--in .pd-price__avail-dot {
  background: #4caf50;
  box-shadow: 0 0 6px rgba(76,175,80,0.6);
}
.pd-price__availability--out { color: var(--color-muted); }
.pd-price__availability--out .pd-price__avail-dot { background: var(--color-muted); }

/* ── Short desc ── */
.pd-info__short-desc {
  font-size: 0.925rem;
  color: var(--color-muted);
  line-height: 1.75;
  margin-bottom: 1.25rem;
}

/* ── Divider ── */
.pd-divider {
  height: 1px;
  background: linear-gradient(90deg, var(--color-brand) 0%, var(--color-border) 30%, transparent 100%);
  margin-bottom: 1.5rem;
}

/* ── Variants ── */
.pd-variants { margin-bottom: 1.5rem; }
.pd-option { margin-bottom: 1.25rem; }
.pd-option__label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--font-heading--family);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-muted);
  margin-bottom: 0.65rem;
}
.pd-option__selected { color: var(--color-foreground); }
.pd-option__btns { display: flex; gap: 0.5rem; flex-wrap: wrap; }

.pd-opt-btn {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 4px;
  color: var(--color-muted);
  cursor: pointer;
  font-family: var(--font-heading--family);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  padding: 0.5rem 1.1rem;
  text-transform: uppercase;
  transition: all var(--transition-fast);
  position: relative;
}
.pd-opt-btn:hover { border-color: var(--color-foreground); color: var(--color-foreground); }
.pd-opt-btn.is-active {
  background: var(--color-brand);
  border-color: var(--color-brand);
  color: #fff;
  box-shadow: 0 2px 12px rgba(198,0,0,0.35);
}

/* ── Form ── */
.pd-form { margin-bottom: 1.25rem; }

.pd-form__row {
  display: flex;
  gap: 0.75rem;
  align-items: stretch;
  margin-bottom: 0.65rem;
}
.pd-form__atc { flex: 1; }

/* Qty */
.pd-qty {
  display: flex;
  align-items: stretch;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
  background: var(--color-surface);
}
.pd-qty__btn {
  background: transparent;
  border: none;
  color: var(--color-foreground);
  cursor: pointer;
  font-size: 1.2rem;
  font-weight: 300;
  width: 2.75rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background var(--transition-fast), color var(--transition-fast);
}
.pd-qty__btn:hover { background: var(--color-surface-2); color: var(--color-brand); }
.pd-qty__input {
  background: transparent;
  border: none;
  border-left: 1px solid var(--color-border);
  border-right: 1px solid var(--color-border);
  color: var(--color-foreground);
  font-family: var(--font-heading--family);
  font-size: 1rem;
  font-weight: 700;
  text-align: center;
  width: 3.25rem;
  -moz-appearance: textfield;
}
.pd-qty__input::-webkit-inner-spin-button,
.pd-qty__input::-webkit-outer-spin-button { -webkit-appearance: none; }

/* Buy Now */
.pd-form__buy-now {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.6rem;
  background: transparent;
  border: 1px solid var(--color-border);
  border-radius: 6px;
  color: var(--color-muted);
  cursor: pointer;
  font-family: var(--font-heading--family);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.85rem;
  transition: all var(--transition-fast);
}
.pd-form__buy-now:hover {
  border-color: var(--color-foreground);
  color: var(--color-foreground);
  background: var(--color-surface);
}

/* ── Trust row ── */
.pd-trust {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: 1.5rem;
}
.pd-trust__item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.85rem 0.5rem;
  font-family: var(--font-heading--family);
  font-size: 0.65rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-muted);
}
.pd-trust__item svg { color: var(--color-brand); flex-shrink: 0; }
.pd-trust__sep {
  width: 1px;
  height: 2rem;
  background: var(--color-border);
  flex-shrink: 0;
}
@media (max-width: 480px) {
  .pd-trust { flex-direction: column; }
  .pd-trust__sep { width: 100%; height: 1px; }
}

/* ── Meta ── */
.pd-meta {
  border: 1px solid var(--color-border);
  border-radius: 6px;
  overflow: hidden;
}
.pd-meta__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.6rem 1rem;
  border-bottom: 1px solid var(--color-border);
  font-size: 0.8rem;
}
.pd-meta__row:last-child { border-bottom: none; }
.pd-meta__row > span:first-child {
  font-family: var(--font-heading--family);
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-muted);
}
.pd-meta__row > span:last-child { color: var(--color-foreground); font-size: 0.82rem; }
.pd-meta__tags { display: flex; gap: 0.4rem; flex-wrap: wrap; justify-content: flex-end; }
.pd-meta__tag {
  background: var(--color-surface-2);
  border: 1px solid var(--color-border);
  border-radius: 3px;
  color: var(--color-muted);
  font-size: 0.7rem;
  padding: 0.15rem 0.5rem;
  transition: color var(--transition-fast), border-color var(--transition-fast);
}
.pd-meta__tag:hover { color: var(--color-brand); border-color: var(--color-brand); }

/* ══ Tabs ══ */
.pd-tabs {
  margin-top: var(--spacing-2xl);
  border-top: 1px solid var(--color-border);
  padding-top: var(--spacing-lg);
}

.pd-tabs__nav {
  display: flex;
  gap: 0;
  border-bottom: 1px solid var(--color-border);
  margin-bottom: 0;
  overflow-x: auto;
  scrollbar-width: none;
}
.pd-tabs__nav::-webkit-scrollbar { display: none; }

.pd-tab-btn {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--color-muted);
  cursor: pointer;
  font-family: var(--font-heading--family);
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 1rem 1.5rem;
  margin-bottom: -1px;
  white-space: nowrap;
  transition: color var(--transition-fast), border-color var(--transition-fast);
}
.pd-tab-btn svg { opacity: 0.5; }
.pd-tab-btn:hover { color: var(--color-foreground); }
.pd-tab-btn.is-active {
  color: var(--color-brand);
  border-bottom-color: var(--color-brand);
}
.pd-tab-btn.is-active svg { opacity: 1; color: var(--color-brand); }

.pd-tabs__body {
  padding: var(--spacing-lg) 0;
}
.pd-tab-panel { display: none; }
.pd-tab-panel.is-active { display: block; }
.pd-tab-panel__empty { color: var(--color-muted); font-size: 0.9rem; font-style: italic; }

/* RTE */
.pd-rte { color: var(--color-muted); font-size: 0.9rem; line-height: 1.8; max-width: 80ch; }
.pd-rte h1, .pd-rte h2, .pd-rte h3, .pd-rte h4 {
  font-family: var(--font-heading--family);
  color: var(--color-foreground);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
}
.pd-rte h2 { font-size: 1.3rem; }
.pd-rte h3 { font-size: 1.05rem; }
.pd-rte p { margin-bottom: 0.875rem; }
.pd-rte ul, .pd-rte ol { padding-left: 1.5rem; margin-bottom: 0.875rem; }
.pd-rte li { margin-bottom: 0.35rem; }
.pd-rte a { color: var(--color-brand); text-decoration: underline; }
.pd-rte strong { color: var(--color-foreground); font-weight: 700; }

/* Shipping tab */
.pd-ship {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
}
@media (max-width: 768px) { .pd-ship { grid-template-columns: 1fr; } }

.pd-ship__card {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-top: 3px solid var(--color-brand);
  border-radius: 6px;
  padding: 1.5rem;
  position: relative;
  overflow: hidden;
}
.pd-ship__card::after {
  content: '';
  position: absolute;
  bottom: -10px; right: -10px;
  width: 60px; height: 60px;
  background: var(--color-brand);
  opacity: 0.04;
  transform: rotate(45deg);
}
.pd-ship__card-icon {
  width: 40px; height: 40px;
  background: rgba(198,0,0,0.1);
  border: 1px solid rgba(198,0,0,0.2);
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-brand);
  margin-bottom: 1rem;
}
.pd-ship__card h4 {
  font-family: var(--font-heading--family);
  font-size: 0.85rem;
  font-weight: 800;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--color-foreground);
  margin-bottom: 1rem;
}
.pd-ship__card ul { list-style: none; padding: 0; margin: 0; }
.pd-ship__card li {
  padding: 0.4rem 0 0.4rem 1rem;
  font-size: 0.85rem;
  color: var(--color-muted);
  position: relative;
  border-bottom: 1px solid var(--color-border);
  line-height: 1.4;
}
.pd-ship__card li:last-child { border-bottom: none; padding-bottom: 0; }
.pd-ship__card li::before {
  content: '›';
  position: absolute;
  left: 0;
  color: var(--color-brand);
  font-weight: 700;
}
.pd-ship__card a { color: var(--color-brand); }

/* ══ Related ══ */
.pd-related {
  margin-top: var(--spacing-2xl);
  padding-top: var(--spacing-xl);
  border-top: 1px solid var(--color-border);
}
.pd-related__header { margin-bottom: var(--spacing-lg); }
.pd-related__eyebrow {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--color-brand);
  margin-bottom: 0.5rem;
}
.pd-related__eyebrow span {
  display: block;
  width: 2rem;
  height: 2px;
  background: var(--color-brand);
  flex-shrink: 0;
}
.pd-related__heading {
  font-family: var(--font-heading--family);
  font-size: clamp(1.5rem, 2.5vw, 2.2rem);
  font-weight: 900;
  text-transform: uppercase;
  color: var(--color-foreground);
  letter-spacing: 0.02em;
}

{% endstylesheet %}

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show related products",
      "default": true
    }
  ]
}
{% endschema %}
