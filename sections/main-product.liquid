{% assign product = product %}
{% assign current_variant = product.selected_or_first_available_variant %}

<section class="product-page section-padding">

  <!-- Breadcrumbs -->
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    <span class="breadcrumbs__sep" aria-hidden="true">/</span>
    {% if collection %}
      <a href="{{ collection.url }}">{{ collection.title }}</a>
      <span class="breadcrumbs__sep" aria-hidden="true">/</span>
    {% endif %}
    <span aria-current="page">{{ product.title }}</span>
  </nav>

  <div class="product-page__grid">

    <!-- Media Gallery -->
    <div class="product-gallery">
      <div class="product-gallery__main" id="product-gallery-main">
        {% for image in product.images limit: 1 %}
          <img
            id="product-main-image"
            src="{{ image | image_url: width: 1200 }}"
            alt="{{ image.alt | default: product.title | escape }}"
            loading="eager"
            width="1200"
            height="1200"
          >
        {% else %}
          <div class="product-gallery__no-image">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect width="200" height="200" fill="#1c1c1c"/>
              <path d="M50 150 L80 90 L110 130 L140 80 L170 150 Z" fill="#2a2a2a"/>
            </svg>
          </div>
        {% endfor %}
      </div>

      {% if product.images.size > 1 %}
        <div class="product-gallery__thumbs">
          {% for image in product.images %}
            <button
              class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
              onclick="document.getElementById('product-main-image').src = '{{ image | image_url: width: 1200 }}'; this.closest('.product-gallery__thumbs').querySelectorAll('.product-gallery__thumb').forEach(t => t.classList.remove('is-active')); this.classList.add('is-active');"
              aria-label="{{ image.alt | default: product.title | append: ' image ' | append: forloop.index | escape }}"
            >
              <img
                src="{{ image | image_url: width: 200 }}"
                alt="{{ image.alt | default: product.title | escape }}"
                loading="lazy"
                width="200"
                height="200"
              >
            </button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="product-info">

      <!-- Header -->
      <div class="product-info__header">
        {% if product.vendor != blank %}
          <a href="{{ routes.collections_url }}/vendors?q={{ product.vendor | url_encode }}" class="product-info__vendor">
            {{ product.vendor }}
          </a>
        {% endif %}

        <h1 class="product-info__title">{{ product.title }}</h1>

        {% if product.metafields.reviews.rating != blank %}
          <div class="product-info__rating" aria-label="{{ product.metafields.reviews.rating.value }} out of 5 stars">
            <div class="stars" style="--rating: {{ product.metafields.reviews.rating.value }}" aria-hidden="true"></div>
            {% if product.metafields.reviews.rating_count != blank %}
              <span class="product-info__review-count">({{ product.metafields.reviews.rating_count.value }} reviews)</span>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Price -->
      <div class="product-info__price" id="product-price">
        <div class="price">
          {% if current_variant.compare_at_price > current_variant.price %}
            <span class="price__current">{{ current_variant.price | money }}</span>
            <span class="price__compare">{{ current_variant.compare_at_price | money }}</span>
            {% assign saving = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price %}
            <span class="price__saving">Save {{ saving }}%</span>
          {% else %}
            <span class="price__current">{{ current_variant.price | money }}</span>
          {% endif %}
        </div>
      </div>

      <!-- Short Description -->
      {% if product.metafields.custom.short_description != blank %}
        <div class="product-info__short-desc">
          {{ product.metafields.custom.short_description }}
        </div>
      {% endif %}

      <!-- Variant Selectors -->
      <div class="product-info__variants">
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <div class="variant-option">
              <div class="variant-option__label">
                {{ option.name }}:
                <span id="selected-{{ option.name | handleize }}">{{ option.selected_value }}</span>
              </div>
              <div class="variant-option__buttons">
                {% for value in option.values %}
                  <button
                    class="variant-btn {% if option.selected_value == value %}variant-btn--selected{% endif %}"
                    data-option-name="{{ option.name | handleize }}"
                    data-option-value="{{ value | escape }}"
                    onclick="selectVariantOption(this, '{{ option.name | handleize }}', '{{ value | escape }}')"
                    type="button"
                  >
                    {{ value }}
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}
        {% endunless %}
      </div>

      <!-- Add to Cart Form -->
      <form method="post" action="/cart/add" id="product-form-{{ product.id }}" class="product-info__form">
        <input type="hidden" name="id" id="product-variant-id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" id="product-quantity-hidden" value="1">

        <div class="product-info__add-row">
          <!-- Quantity -->
          <div class="quantity-selector">
            <button
              type="button"
              class="quantity-selector__btn"
              onclick="adjustQty(-1)"
              aria-label="Decrease quantity"
            >−</button>
            <input
              type="number"
              id="product-qty"
              class="quantity-selector__input"
              value="1"
              min="1"
              onchange="document.getElementById('product-quantity-hidden').value = this.value"
              aria-label="Quantity"
            >
            <button
              type="button"
              class="quantity-selector__btn"
              onclick="adjustQty(1)"
              aria-label="Increase quantity"
            >+</button>
          </div>

          <!-- Add to Cart -->
          <button
            type="submit"
            id="add-to-cart-btn"
            class="btn btn--primary btn--large product-info__atc"
            {% unless current_variant.available %}disabled{% endunless %}
          >
            {% if current_variant.available %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
              Add to Cart
            {% else %}
              Sold Out
            {% endif %}
          </button>
        </div>

        <!-- Buy Now -->
        {% if current_variant.available %}
          <button
            type="button"
            class="btn btn--secondary btn--full product-info__buy-now"
            onclick="buyNow()"
          >
            Buy Now
          </button>
        {% endif %}
      </form>

      <!-- Trust Badges -->
      <div class="product-info__trust">
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          Secure Checkout
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          Fast Shipping
        </div>
        <div class="trust-badge">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          Easy Returns
        </div>
      </div>

      <!-- Product Details Tabs -->
      <div class="product-tabs">
        <div class="product-tabs__nav">
          <button class="product-tab-btn is-active" onclick="switchTab(this, 'description-{{ product.id }}')" type="button">Description</button>
          <button class="product-tab-btn" onclick="switchTab(this, 'specs-{{ product.id }}')" type="button">Specifications</button>
          <button class="product-tab-btn" onclick="switchTab(this, 'shipping-{{ product.id }}')" type="button">Shipping</button>
        </div>

        <div id="description-{{ product.id }}" class="product-tab-content is-active">
          {% if product.description != blank %}
            <div class="rte">{{ product.description }}</div>
          {% else %}
            <p>No description available yet.</p>
          {% endif %}
        </div>

        <div id="specs-{{ product.id }}" class="product-tab-content">
          {% if product.metafields.custom.specifications != blank %}
            <div class="rte">{{ product.metafields.custom.specifications }}</div>
          {% else %}
            <p>Specifications will be listed here. Contact us for detailed fitment information.</p>
          {% endif %}
        </div>

        <div id="shipping-{{ product.id }}" class="product-tab-content">
          <div class="shipping-info">
            <h4>Shipping & Delivery</h4>
            <ul>
              <li>Standard shipping 3–7 business days</li>
              <li>Express shipping 1–3 business days</li>
              <li>Free standard shipping on orders over $150</li>
              <li>All orders dispatched from our Australian warehouse</li>
            </ul>
            <h4>Returns</h4>
            <ul>
              <li>30-day returns on unused, uninstalled parts</li>
              <li>Original packaging required</li>
              <li><a href="/policies/refund-policy">Full return policy →</a></li>
            </ul>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Related Products -->
  {% if section.settings.show_related and product.collections.first %}
    <div class="product-page__related">
      <div class="section-header">
        <div>
          <p class="section-header__eyebrow">You May Also Like</p>
          <h2 class="section-header__title">Related Parts</h2>
        </div>
      </div>
      <div class="product-grid">
        {% assign related_collection = product.collections.first %}
        {% for related_product in related_collection.products limit: 4 %}
          {% unless related_product.id == product.id %}
            {% render 'product-card', product: related_product %}
          {% endunless %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

</section>

<script>
  function adjustQty(delta) {
    var input = document.getElementById('product-qty');
    var newVal = Math.max(1, (parseInt(input.value) || 1) + delta);
    input.value = newVal;
    document.getElementById('product-quantity-hidden').value = newVal;
  }

  function switchTab(btn, tabId) {
    btn.closest('.product-tabs').querySelectorAll('.product-tab-btn').forEach(function(b) { b.classList.remove('is-active'); });
    btn.closest('.product-tabs').querySelectorAll('.product-tab-content').forEach(function(c) { c.classList.remove('is-active'); });
    btn.classList.add('is-active');
    document.getElementById(tabId).classList.add('is-active');
  }

  function selectVariantOption(btn, optionName, value) {
    btn.closest('.variant-option').querySelectorAll('.variant-btn').forEach(function(b) { b.classList.remove('variant-btn--selected'); });
    btn.classList.add('variant-btn--selected');
    var label = document.getElementById('selected-' + optionName);
    if (label) label.textContent = value;
  }

  function buyNow() {
    var form = document.getElementById('product-form-{{ product.id }}');
    var variantId = document.getElementById('product-variant-id').value;
    var qty = document.getElementById('product-qty').value;
    window.location.href = '/cart/' + variantId + ':' + qty + '?checkout=true';
  }
</script>

{% stylesheet %}
  .product-page {
    padding: var(--spacing-lg) var(--page-margin) var(--spacing-2xl);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .product-page__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    margin-top: var(--spacing-md);
    align-items: start;
  }

  @media (max-width: 900px) {
    .product-page__grid { grid-template-columns: 1fr; gap: var(--spacing-lg); }
  }

  /* Gallery */
  .product-gallery__main {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    aspect-ratio: 1;
    position: relative;
  }

  .product-gallery__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-gallery__no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-gallery__no-image svg {
    width: 100%;
    height: 100%;
  }

  .product-gallery__thumbs {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }

  .product-gallery__thumb {
    width: 72px;
    height: 72px;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: var(--style-border-radius-cards);
    overflow: hidden;
    cursor: pointer;
    transition: border-color var(--transition-fast);
    padding: 0;
  }

  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-gallery__thumb.is-active,
  .product-gallery__thumb:hover {
    border-color: var(--color-brand);
  }

  /* Product Info */
  .product-info__vendor {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brand);
    display: inline-block;
    margin-bottom: 0.5rem;
  }

  .product-info__title {
    font-size: clamp(1.6rem, 3vw, 2.5rem);
    margin-bottom: 0.75rem;
  }

  .product-info__rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .product-info__review-count {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .product-info__price {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .product-info__short-desc {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.65;
    margin-bottom: 1.5rem;
  }

  .product-info__variants {
    margin-bottom: 1.5rem;
  }

  .product-info__add-row {
    display: flex;
    gap: 0.75rem;
    align-items: stretch;
    margin-bottom: 0.75rem;
  }

  .product-info__atc {
    flex: 1;
  }

  .product-info__buy-now {
    margin-bottom: 1.5rem;
  }

  /* Trust badges */
  .product-info__trust {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
    padding: 1rem;
    background: var(--color-surface-2);
    border-radius: var(--style-border-radius-cards);
    border: 1px solid var(--color-border);
  }

  .trust-badge {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .trust-badge svg {
    color: var(--color-brand);
  }

  /* Product Tabs */
  .product-tabs__nav {
    display: flex;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 1.25rem;
    gap: 0;
  }

  .product-tab-btn {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--color-muted);
    cursor: pointer;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.75rem 1.25rem;
    margin-bottom: -1px;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .product-tab-btn:hover { color: var(--color-foreground); }

  .product-tab-btn.is-active {
    color: var(--color-brand);
    border-bottom-color: var(--color-brand);
  }

  .product-tab-content {
    display: none;
  }

  .product-tab-content.is-active {
    display: block;
  }

  /* RTE (rich text) */
  .rte {
    color: var(--color-muted);
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .rte h1, .rte h2, .rte h3, .rte h4 {
    color: var(--color-foreground);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
    text-transform: none;
    letter-spacing: 0;
  }

  .rte ul, .rte ol {
    padding-left: 1.5rem;
  }

  .rte li {
    margin-bottom: 0.4rem;
  }

  .rte a {
    color: var(--color-brand);
    text-decoration: underline;
  }

  /* Shipping info */
  .shipping-info h4 {
    font-size: 0.9rem;
    color: var(--color-foreground);
    text-transform: none;
    letter-spacing: 0;
    margin-top: 1.25rem;
    margin-bottom: 0.6rem;
  }

  .shipping-info h4:first-child { margin-top: 0; }

  .shipping-info ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .shipping-info li {
    padding: 0.35rem 0;
    padding-left: 1rem;
    font-size: 0.875rem;
    color: var(--color-muted);
    position: relative;
  }

  .shipping-info li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-brand);
    font-size: 0.7rem;
  }

  .shipping-info a {
    color: var(--color-brand);
  }

  /* Related */
  .product-page__related {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-border);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show related products",
      "default": true
    }
  ]
}
{% endschema %}
