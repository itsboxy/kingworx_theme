<!-- Contact Page Hero -->
<div class="contact-hero full-width">
  <div class="contact-hero__slash" aria-hidden="true"></div>
  <div class="contact-hero__inner">
    <p class="contact-hero__eyebrow">Get in Touch</p>
    <h1 class="contact-hero__heading">Contact <span class="contact-hero__accent">KingWorX</span></h1>
    <p class="contact-hero__sub">Questions about fitment, orders, or builds? Our team is here to help.</p>
  </div>
</div>

<!-- Contact Body -->
<div class="contact-body">

  <!-- Info Cards -->
  <div class="contact-info">

    <div class="contact-card">
      <div class="contact-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      </div>
      <h3>Email Us</h3>
      <p>For orders, fitment questions, and general enquiries.</p>
      <a href="mailto:support@kingworx.com.au">support@kingworx.com.au</a>
    </div>

    <div class="contact-card">
      <div class="contact-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>
      </div>
      <h3>Response Time</h3>
      <p>We aim to respond within 1–2 business days, Monday–Friday.</p>
      <span>Mon–Fri, 9am–5pm AEST</span>
    </div>

    <div class="contact-card">
      <div class="contact-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
      </div>
      <h3>Based In</h3>
      <p>Designed and operated from Australia. Shipping Australia-wide.</p>
      <span>Australia</span>
    </div>

  </div>

  <!-- Contact Form -->
  <div class="contact-form-wrap">
    <div class="contact-form-header">
      <p class="contact-form-header__eyebrow">Send a Message</p>
      <h2 class="contact-form-header__title">How Can We Help?</h2>
    </div>

    {% form 'contact', id: 'ContactForm' %}
      {% if form.posted_successfully? %}
        <div class="contact-success">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <div>
            <strong>Message sent!</strong>
            <p>Thanks for reaching out. We'll get back to you within 1–2 business days.</p>
          </div>
        </div>
      {% endif %}

      {% if form.errors %}
        <div class="contact-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Please fix the errors below and try again.
        </div>
      {% endif %}

      <div class="contact-form__grid">
        <div class="contact-form__field">
          <label class="form-label" for="ContactForm-name">Full Name <span class="required">*</span></label>
          <input
            type="text"
            id="ContactForm-name"
            name="contact[name]"
            value="{{ form.name }}"
            placeholder="John Smith"
            class="form-input {% if form.errors contains 'name' %}is-error{% endif %}"
            required
            autocomplete="name"
          >
        </div>

        <div class="contact-form__field">
          <label class="form-label" for="ContactForm-email">Email Address <span class="required">*</span></label>
          <input
            type="email"
            id="ContactForm-email"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="you@email.com"
            class="form-input {% if form.errors contains 'email' %}is-error{% endif %}"
            required
            autocomplete="email"
          >
        </div>

        <div class="contact-form__field">
          <label class="form-label" for="ContactForm-subject">Subject</label>
          <select id="ContactForm-subject" name="contact[subject]" class="form-input">
            <option value="">Select a topic...</option>
            <option value="Order enquiry">Order Enquiry</option>
            <option value="Fitment question">Fitment Question</option>
            <option value="Returns & warranty">Returns & Warranty</option>
            <option value="Wholesale enquiry">Wholesale Enquiry</option>
            <option value="General">General</option>
          </select>
        </div>

        <div class="contact-form__field">
          <label class="form-label" for="ContactForm-phone">Phone (optional)</label>
          <input
            type="tel"
            id="ContactForm-phone"
            name="contact[phone]"
            value="{{ form.phone }}"
            placeholder="04XX XXX XXX"
            class="form-input"
            autocomplete="tel"
          >
        </div>
      </div>

      <div class="contact-form__field contact-form__field--full">
        <label class="form-label" for="ContactForm-body">Message <span class="required">*</span></label>
        <textarea
          id="ContactForm-body"
          name="contact[body]"
          rows="6"
          placeholder="Describe your enquiry — include your vehicle make/model if asking about fitment."
          class="form-input {% if form.errors contains 'body' %}is-error{% endif %}"
          required
        >{{ form.body }}</textarea>
      </div>

      <div class="contact-form__footer">
        <button type="submit" class="btn btn--primary btn--large">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Send Message
        </button>
        <p class="contact-form__note">We'll respond within 1–2 business days.</p>
      </div>

    {% endform %}
  </div>

</div>

{% stylesheet %}
  /* ── Contact Hero ── */
  .contact-hero {
    background: linear-gradient(135deg, #0d0d0d 0%, #1a0000 60%, #0a0a0a 100%);
    position: relative;
    overflow: hidden;
    padding: 5rem var(--page-margin) 4rem;
    border-bottom: 3px solid var(--color-brand);
  }
  .contact-hero__slash {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -65deg, transparent 0, transparent 60px,
      rgba(198,0,0,0.04) 60px, rgba(198,0,0,0.04) 61px
    );
    pointer-events: none;
  }
  .contact-hero__inner {
    position: relative;
    z-index: 1;
    max-width: var(--page-width);
    margin: 0 auto;
  }
  .contact-hero__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .contact-hero__eyebrow::before {
    content: '';
    display: inline-block;
    width: 2rem; height: 2px;
    background: var(--color-brand);
  }
  .contact-hero__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    color: #fff;
    line-height: 1.05;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .contact-hero__accent { color: var(--color-brand); }
  .contact-hero__sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    max-width: 52ch;
    line-height: 1.65;
  }

  /* ── Contact Body ── */
  .contact-body {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 3.5rem var(--page-margin) 5rem;
  }

  /* ── Info Cards ── */
  .contact-info {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }
  @media (max-width: 768px) {
    .contact-info { grid-template-columns: 1fr; }
  }

  .contact-card {
    background: #ffffff;
    border: 1px solid #e8e8e8;
    border-top: 3px solid var(--color-brand);
    border-radius: 6px;
    padding: 1.75rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .contact-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.09);
  }
  .contact-card__icon {
    color: var(--color-brand);
    margin-bottom: 1rem;
  }
  .contact-card h3 {
    font-family: var(--font-heading--family);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #111111;
    margin-bottom: 0.5rem;
  }
  .contact-card p {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }
  .contact-card a,
  .contact-card span {
    font-family: var(--font-heading--family);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--color-brand);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  .contact-card a:hover { opacity: 0.75; }

  /* ── Form ── */
  .contact-form-header {
    margin-bottom: 2rem;
  }
  .contact-form-header__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .contact-form-header__eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.5rem; height: 2px;
    background: var(--color-brand);
  }
  .contact-form-header__title {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: #111111;
    margin: 0;
  }

  .contact-form-wrap {
    background: #ffffff;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    padding: 2.5rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }

  .contact-form__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.25rem;
  }
  @media (max-width: 640px) {
    .contact-form__grid { grid-template-columns: 1fr; }
    .contact-form-wrap { padding: 1.5rem; }
  }

  .contact-form__field { display: flex; flex-direction: column; gap: 0.4rem; }
  .contact-form__field--full { margin-bottom: 1.5rem; }

  .form-input.is-error { border-color: var(--color-brand); }

  .required { color: var(--color-brand); }

  .contact-form__footer {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .contact-form__note {
    font-size: 0.8rem;
    color: #888;
    margin: 0;
  }

  /* Success / Error states */
  .contact-success {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #f0faf2;
    border: 1px solid #a8e0b5;
    border-left: 3px solid #2e9e4f;
    border-radius: 4px;
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    color: #1d5c2e;
  }
  .contact-success svg { color: #2e9e4f; flex-shrink: 0; margin-top: 2px; }
  .contact-success strong { display: block; font-size: 0.9rem; margin-bottom: 0.25rem; }
  .contact-success p { font-size: 0.85rem; margin: 0; color: #2e5c3a; }

  .contact-error {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(198,0,0,0.06);
    border: 1px solid rgba(198,0,0,0.25);
    border-left: 3px solid var(--color-brand);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
    color: var(--color-brand);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact Page",
  "settings": [],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
