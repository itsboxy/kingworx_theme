{% assign hero_height = section.settings.hero_height %}

<section class="hero full-width hero--{{ hero_height }}">
  {% if section.settings.image %}
    <div class="hero__media">
      <img
        src="{{ section.settings.image | image_url: width: 2400 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        loading="eager"
        fetchpriority="high"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
      >
    </div>
  {% else %}
    <div class="hero__media hero__media--placeholder">
      <div class="hero__placeholder-bg"></div>
    </div>
  {% endif %}

  <div class="hero__overlay"></div>
  <div class="hero__red-slash" aria-hidden="true"></div>
  <div class="hero__glow" aria-hidden="true"></div>

  <div class="hero__content hero__content--{{ section.settings.content_position }}">
    {% if section.settings.eyebrow != blank %}
      <p class="hero__eyebrow">
        <span class="hero__eyebrow-line"></span>
        {{ section.settings.eyebrow }}
        <span class="hero__eyebrow-line"></span>
      </p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h1 class="hero__heading">
        {%- assign words = section.settings.heading | split: ' ' -%}
        {%- for word in words -%}
          {%- if forloop.last -%}
            <span class="hero__heading-accent">{{ word }}</span>
          {%- else -%}
            {{ word }}{% unless forloop.last %} {% endunless %}
          {%- endif -%}
        {%- endfor -%}
      </h1>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.button_label != blank %}
      <div class="hero__actions">
        <a href="{{ section.settings.button_url }}" class="btn btn--primary btn--large hero__btn-primary">
          {{ section.settings.button_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        {% if section.settings.button_2_label != blank %}
          <a href="{{ section.settings.button_2_url }}" class="btn btn--secondary btn--large">
            {{ section.settings.button_2_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if section.settings.show_scroll_indicator %}
    <div class="hero__scroll-indicator" aria-hidden="true">
      <div class="hero__scroll-indicator-line"></div>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: 85vh;
  }

  .hero--short    { min-height: 55vh; }
  .hero--medium   { min-height: 75vh; }
  .hero--tall     { min-height: 90vh; }
  .hero--fullscreen { min-height: 100svh; }

  /* Media */
  .hero__media { position: absolute; inset: 0; z-index: 0; }
  .hero__media img { width: 100%; height: 100%; object-fit: cover; object-position: center; }
  .hero__media--placeholder { background: #0a0a0a; }

  .hero__placeholder-bg {
    position: absolute; inset: 0;
    background:
      repeating-linear-gradient(
        -45deg,
        transparent, transparent 40px,
        rgba(198,0,0,0.025) 40px, rgba(198,0,0,0.025) 41px
      ),
      linear-gradient(180deg, #0d0d0d 0%, #131313 100%);
  }

  /* Overlays */
  .hero__overlay {
    position: absolute; inset: 0; z-index: 1;
    background:
      linear-gradient(90deg, rgba(0,0,0,0.88) 0%, rgba(0,0,0,0.55) 55%, rgba(0,0,0,0.15) 100%),
      linear-gradient(0deg, rgba(0,0,0,0.4) 0%, transparent 50%);
  }

  /* Red diagonal slash accent */
  .hero__red-slash {
    position: absolute;
    top: 0; bottom: 0;
    left: 55%; width: 4px;
    background: linear-gradient(180deg, transparent 0%, var(--color-brand) 30%, var(--color-brand) 70%, transparent 100%);
    transform: skewX(-8deg);
    opacity: 0.5;
    z-index: 2;
    pointer-events: none;
  }

  /* Red ambient glow behind content */
  .hero__glow {
    position: absolute;
    bottom: -10%; left: -5%;
    width: 60%; height: 80%;
    background: radial-gradient(ellipse at 20% 80%, rgba(198,0,0,0.12) 0%, transparent 60%);
    z-index: 1;
    pointer-events: none;
  }

  /* Content */
  .hero__content {
    position: relative; z-index: 3;
    padding: var(--spacing-2xl) var(--page-margin);
    max-width: var(--page-width);
    margin: 0 auto; width: 100%;
  }
  .hero__content > * { max-width: 58ch; }
  .hero__content--center {
    text-align: center;
    display: flex; flex-direction: column; align-items: center;
  }
  .hero__content--center > * { max-width: 52ch; }

  /* Eyebrow */
  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-heading--family);
    font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 1.5rem;
    background: rgba(198,0,0,0.1);
    border: 1px solid rgba(198,0,0,0.25);
    padding: 0.4rem 1rem;
    border-radius: 2px;
  }
  .hero__eyebrow-line {
    display: block; width: 1.2rem; height: 1px;
    background: var(--color-brand); flex-shrink: 0;
  }

  /* Heading */
  .hero__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(3rem, 7.5vw, 7rem);
    font-weight: 700; line-height: 0.93;
    letter-spacing: -0.01em; text-transform: uppercase;
    color: #ffffff; margin-bottom: 1.5rem;
  }
  .hero__heading-accent { color: var(--color-brand); }

  /* Subheading */
  .hero__subheading {
    font-size: 1.05rem; line-height: 1.7;
    color: rgba(255,255,255,0.6);
    margin-bottom: 2.75rem; max-width: 50ch;
    border-left: 2px solid var(--color-brand);
    padding-left: 1rem;
  }
  .hero__content--center .hero__subheading { border-left: none; padding-left: 0; }

  /* Actions */
  .hero__actions { display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; }

  .hero__btn-primary {
    box-shadow: 0 0 30px rgba(198,0,0,0.45), 0 4px 20px rgba(198,0,0,0.3) !important;
  }
  .hero__btn-primary:hover {
    box-shadow: 0 0 50px rgba(198,0,0,0.65), 0 8px 30px rgba(198,0,0,0.5) !important;
  }

  /* Scroll indicator */
  .hero__scroll-indicator {
    position: absolute; bottom: 2.5rem; left: 50%;
    transform: translateX(-50%); z-index: 3;
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
  }
  .hero__scroll-indicator-line {
    width: 1px; height: 50px;
    background: linear-gradient(to bottom, var(--color-brand), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.25; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  @media (max-width: 768px) {
    .hero__heading { font-size: clamp(2.5rem, 11vw, 4rem); }
    .hero__overlay { background: rgba(0,0,0,0.75); }
    .hero__content > * { max-width: 100%; }
    .hero__red-slash { display: none; }
    .hero__subheading { border-left: none; padding-left: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Height",
      "options": [
        { "value": "short", "label": "Short (55vh)" },
        { "value": "medium", "label": "Medium (75vh)" },
        { "value": "tall", "label": "Tall (90vh)" },
        { "value": "fullscreen", "label": "Full screen" }
      ],
      "default": "tall"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Content alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Engineered in Australia"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Performance Parts That Perform"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Precision-designed aero kits, underbody components, and performance parts. Built for fitment. Built for the road."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Second button label"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Second button link"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_indicator",
      "label": "Show scroll indicator",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Image"
    }
  ]
}
{% endschema %}
