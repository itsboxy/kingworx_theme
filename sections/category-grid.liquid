<section class="category-grid-section section-padding">
  {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
    <div class="section-header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <p class="section-header__eyebrow">{{ section.settings.eyebrow }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="section-header__title">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    </div>
  {% endif %}

  <div class="category-grid category-grid--{{ section.settings.layout }}">
    {% for block in section.blocks %}
      {% assign col = section.settings.collection %}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="category-card {% if forloop.first and section.settings.layout == 'featured' %}category-card--featured{% endif %}"
        {{ block.shopify_attributes }}
      >
        <div class="category-card__media">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 900 }}"
              alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
              loading="lazy"
              width="900"
              height="600"
            >
          {% else %}
            <div class="category-card__placeholder">
              <svg viewBox="0 0 200 140" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <rect width="200" height="140" fill="#1c1c1c"/>
                <path d="M40 110 L70 60 L100 90 L130 50 L160 110 Z" fill="#2a2a2a" stroke="#333" stroke-width="1"/>
                <circle cx="150" cy="45" r="15" fill="#222" stroke="#333" stroke-width="1"/>
              </svg>
            </div>
          {% endif %}
          <div class="category-card__overlay"></div>
        </div>

        <div class="category-card__content">
          {% if block.settings.eyebrow != blank %}
            <span class="category-card__eyebrow">{{ block.settings.eyebrow }}</span>
          {% endif %}
          <h3 class="category-card__title">{{ block.settings.title }}</h3>
          {% if block.settings.count != blank %}
            <span class="category-card__count">{{ block.settings.count }}</span>
          {% endif %}
          <span class="category-card__arrow" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .category-grid-section {
    padding: var(--spacing-2xl) var(--page-margin);
    max-width: var(--page-width);
    margin: 0 auto;
  }

  /* Grid layouts */
  .category-grid {
    display: grid;
    gap: 1.25rem;
  }

  .category-grid--grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .category-grid--grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .category-grid--featured {
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: auto auto;
  }

  .category-grid--featured .category-card--featured {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  @media (max-width: 1024px) {
    .category-grid--grid-4 { grid-template-columns: repeat(2, 1fr); }
    .category-grid--featured { grid-template-columns: repeat(2, 1fr); }
    .category-grid--featured .category-card--featured { grid-column: 1 / -1; grid-row: 1; }
  }

  @media (max-width: 640px) {
    .category-grid--grid-3,
    .category-grid--grid-4,
    .category-grid--featured { grid-template-columns: repeat(2, 1fr); }
    .category-grid--featured .category-card--featured { grid-column: 1 / -1; }
  }

  @media (max-width: 420px) {
    .category-grid--grid-3,
    .category-grid--grid-4 { grid-template-columns: 1fr; }
  }

  /* Card */
  .category-card {
    position: relative;
    display: block;
    overflow: hidden;
    border-radius: var(--style-border-radius-cards);
    border: 1px solid var(--color-border);
    aspect-ratio: 4 / 3;
    transition: border-color var(--transition-base), transform var(--transition-base);
  }

  .category-card--featured {
    aspect-ratio: 16 / 9;
  }

  .category-card:hover {
    border-color: var(--color-brand);
    transform: translateY(-3px);
  }

  .category-card__media {
    position: absolute;
    inset: 0;
  }

  .category-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .category-card:hover .category-card__media img {
    transform: scale(1.07);
  }

  .category-card__placeholder {
    width: 100%;
    height: 100%;
  }

  .category-card__placeholder svg {
    width: 100%;
    height: 100%;
  }

  .category-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.2) 50%,
      rgba(0, 0, 0, 0) 100%
    );
    transition: background var(--transition-base);
  }

  .category-card:hover .category-card__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.4) 50%,
      rgba(0, 0, 0, 0.1) 100%
    );
  }

  .category-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    z-index: 2;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .category-card__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand);
  }

  .category-card__title {
    font-family: var(--font-heading--family);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: #fff;
    line-height: 1.1;
    margin: 0;
  }

  .category-card--featured .category-card__title {
    font-size: 2rem;
  }

  .category-card__count {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.55);
  }

  .category-card__arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    color: #fff;
    opacity: 0;
    transform: translateX(-6px);
    transition: all var(--transition-base);
  }

  .category-card:hover .category-card__arrow {
    opacity: 1;
    transform: translateX(0);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Category Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Browse by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by Category"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid-3", "label": "3 columns" },
        { "value": "grid-4", "label": "4 columns" },
        { "value": "featured", "label": "Featured (large + small)" }
      ],
      "default": "featured"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Aero Kits"
        },
        {
          "type": "text",
          "id": "count",
          "label": "Product count label",
          "default": "12 Products"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Grid",
      "category": "Collections",
      "blocks": [
        { "type": "category", "settings": { "title": "Aero Kits", "eyebrow": "Underbody" } },
        { "type": "category", "settings": { "title": "Performance", "eyebrow": "Engine" } },
        { "type": "category", "settings": { "title": "Suspension", "eyebrow": "Chassis" } }
      ]
    }
  ]
}
{% endschema %}
