<section class="newsletter-section full-width">
  <div class="newsletter-section__inner">
    <div class="newsletter-section__content">
      <p class="newsletter-section__eyebrow">Stay in the Loop</p>
      <h2 class="newsletter-section__heading">{{ section.settings.heading }}</h2>
      <p class="newsletter-section__subtext">{{ section.settings.subtext }}</p>
    </div>

    <form
      method="post"
      action="/contact#newsletter-section"
      id="newsletter-{{ section.id }}"
      class="newsletter-section__form"
    >
      <input type="hidden" name="form_type" value="customer">
      <input type="hidden" name="utf8" value="✓">
      <input type="hidden" name="contact[tags]" value="newsletter">

      <div class="newsletter-section__field">
        <input
          type="email"
          name="contact[email]"
          id="newsletter-email-{{ section.id }}"
          class="newsletter-section__input"
          placeholder="{{ section.settings.placeholder }}"
          aria-label="Email address"
          required
          autocomplete="email"
        >
        <button type="submit" class="btn btn--primary btn--large newsletter-section__submit">
          {{ section.settings.button_label }}
        </button>
      </div>

      <p class="newsletter-section__disclaimer">
        By subscribing you agree to our <a href="/policies/privacy-policy">Privacy Policy</a>.
        No spam, ever.
      </p>
    </form>
  </div>
</section>

{% stylesheet %}
  .newsletter-section {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .newsletter-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand), transparent);
  }

  .newsletter-section__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 3.5rem var(--page-margin);
  }

  .newsletter-section__content {
    flex: 1;
    max-width: 40ch;
  }

  .newsletter-section__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-brand);
    margin-bottom: 0.5rem;
  }

  .newsletter-section__heading {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .newsletter-section__subtext {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
  }

  .newsletter-section__form {
    flex: 1;
    max-width: 480px;
  }

  .newsletter-section__field {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .newsletter-section__input {
    flex: 1;
    background: var(--color-surface-2);
    border: 1px solid var(--color-border);
    border-radius: var(--style-border-radius-inputs);
    color: var(--color-foreground);
    font-size: 0.9rem;
    padding: 0.85rem 1.1rem;
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
  }

  .newsletter-section__input:focus {
    border-color: var(--color-brand);
    box-shadow: 0 0 0 2px rgba(var(--color-brand-rgb), 0.2);
  }

  .newsletter-section__submit {
    flex-shrink: 0;
  }

  .newsletter-section__disclaimer {
    font-size: 0.72rem;
    color: var(--color-muted);
    margin: 0;
    line-height: 1.5;
  }

  .newsletter-section__disclaimer a {
    color: var(--color-muted);
    text-decoration: underline;
  }

  .newsletter-section__disclaimer a:hover {
    color: var(--color-brand);
  }

  @media (max-width: 768px) {
    .newsletter-section__inner {
      flex-direction: column;
      gap: 2rem;
      text-align: center;
    }

    .newsletter-section__content { max-width: 100%; }
    .newsletter-section__form { width: 100%; max-width: 100%; }

    .newsletter-section__field {
      flex-direction: column;
    }

    .newsletter-section__submit {
      width: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Get the Latest Drops & Deals"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "New product launches, build guides, and exclusive discounts for subscribers only."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter",
      "category": "Promotional"
    }
  ]
}
{% endschema %}
