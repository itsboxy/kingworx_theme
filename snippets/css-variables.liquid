{% style %}
  {{ settings.type_primary_font | font_face: font_display: 'swap' }}
  {{ settings.type_primary_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_face: font_display: 'swap' }}
  {{ settings.type_heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

  :root {
    /* Typography */
    --font-body--family: {{ settings.type_primary_font.family }}, {{ settings.type_primary_font.fallback_families }};
    --font-body--weight: {{ settings.type_primary_font.weight }};
    --font-body--style: {{ settings.type_primary_font.style }};
    --font-heading--family: {{ settings.type_heading_font.family }}, {{ settings.type_heading_font.fallback_families }};
    --font-heading--weight: {{ settings.type_heading_font.weight }};
    --font-heading--style: {{ settings.type_heading_font.style }};
    --font-primary--family: var(--font-body--family);
    --font-primary--style: var(--font-body--style);
    --font-primary--weight: var(--font-body--weight);
    --font-body-size: {{ settings.font_body_size }}px;

    /* Brand Colors */
    --color-brand: {{ settings.color_brand }};
    --color-brand-hover: {{ settings.color_brand_hover }};
    --color-brand-rgb: 198, 0, 0;
    --color-brand-glow: rgba(198, 0, 0, 0.35);
    --color-brand-glow-soft: rgba(198, 0, 0, 0.12);

    /* Backgrounds */
    --color-background: {{ settings.background_color }};
    --color-surface: {{ settings.color_surface }};
    --color-surface-2: {{ settings.color_surface_2 }};

    /* Text */
    --color-foreground: {{ settings.foreground_color }};
    --color-muted: {{ settings.color_muted }};

    /* Borders */
    --color-border: {{ settings.color_border }};

    /* Gradients */
    --gradient-red: linear-gradient(135deg, #c60000, #ff2020);
    --gradient-dark: linear-gradient(180deg, #111111 0%, #1a1a1a 100%);
    --gradient-surface: linear-gradient(135deg, #f8f8f8, #f0f0f0);
    --gradient-red-glow: radial-gradient(ellipse at center, rgba(198,0,0,0.1) 0%, transparent 70%);

    /* Layout */
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
    --style-border-radius-cards: {{ settings.card_corner_radius }}px;

    /* Spacing */
    --spacing-xs: 0.5rem;
    --spacing-sm: 1rem;
    --spacing-md: 1.5rem;
    --spacing-lg: 2.5rem;
    --spacing-xl: 4rem;
    --spacing-2xl: 6rem;

    /* Transitions */
    --transition-fast: 150ms ease;
    --transition-base: 250ms ease;
    --transition-slow: 400ms ease;

    /* Header */
    --header-height: 5rem;
    --announcement-height: 2.5rem;

    /* Shadows */
    --shadow-card: 0 4px 24px rgba(0,0,0,0.4);
    --shadow-card-hover: 0 12px 48px rgba(0,0,0,0.6), 0 0 0 1px rgba(198,0,0,0.15);
    --shadow-btn-red: 0 4px 20px rgba(198,0,0,0.3);
    --shadow-btn-red-hover: 0 6px 30px rgba(198,0,0,0.55);
  }
{% endstyle %}
